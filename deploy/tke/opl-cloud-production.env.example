# OPL Cloud TKE production environment template.
#
# Copy values from this template into your secret manager, Kubernetes Secrets,
# or an ignored local .env.production file. Do not commit real passwords,
# API keys, kubeconfig contents, or TCR credentials.

OPL_RUNTIME_PROVIDER=tencent-tke

# Public entrypoints.
OPL_PUBLIC_URL=https://cloud.medopl.cn
OPL_CONSOLE_DOMAIN=cloud.medopl.cn
OPL_WORKSPACE_DOMAIN=workspace.medopl.cn
OPL_INGRESS_CLASS=qcloud
# Tencent TKE qcloud Ingress expects each Kubernetes Secret to contain a
# qcloud_cert_id entry, not raw PEM certificate material. Use OPL_TLS_CERT_ID
# for one multi-domain/wildcard certificate, or the per-host ids below for two
# single-domain certificates.
OPL_TLS_CERT_ID=
OPL_CONSOLE_TLS_SECRET_NAME=opl-cloud-console-medopl-cn-tls
OPL_CONSOLE_TLS_CERT_ID=<tencent-ssl-certificate-id-for-cloud-medopl-cn>
OPL_WORKSPACE_TLS_SECRET_NAME=opl-cloud-workspace-medopl-cn-tls
OPL_WORKSPACE_TLS_CERT_ID=<tencent-ssl-certificate-id-for-workspace-medopl-cn>

# Tencent TKE deployment target.
# The v22 MedOPL TKE cluster, TCR namespace, kubeconfig, and PostgreSQL are now
# treated as the OPL Cloud production resource pool.
OPL_K8S_NAMESPACE=opl-cloud
TENCENT_DEPLOY_KUBECONFIG_REF=/home/dev/.secrets/medopl/v22/kubeconfig-package-d-deploy
TENCENT_DEPLOY_CLUSTER_ID=<copy-from-v22-package-d-deploy-env>
TENCENT_TCR_REGISTRY=<copy-from-v22-package-d-deploy-env>
TENCENT_TCR_NAMESPACE=<copy-from-v22-package-d-deploy-env>
TENCENT_TCR_REGION=<copy-from-v22-package-d-deploy-env>
OPL_IMAGE_PULL_SECRET_NAME=tcr-pull-secret

# OPL Cloud control-plane image built from this repository.
OPL_CLOUD_IMAGE=<tcr-registry>/<tcr-namespace>/opl-cloud:<tag>

# Workspace runtime image. This is the one-person-lab-app runtime image.
OPL_WORKSPACE_IMAGE=<tcr-registry>/<tcr-namespace>/one-person-lab-app:<tag>
OPL_WORKSPACE_WEBUI_PORT=3000
OPL_WORKSPACE_DATA_DIR=/data
OPL_WORKSPACE_PROJECTS_DIR=/projects

# Workspace scheduling and persistence.
OPL_WORKSPACE_STORAGE_CLASS=<confirm-from-tke-storageclass>
OPL_WORKSPACE_VOLUME_SNAPSHOT_CLASS=<confirm-from-tke-volumesnapshotclass>
OPL_WORKSPACE_NODE_SELECTOR_KEY=medopl.cn/workload
OPL_WORKSPACE_NODE_SELECTOR_VALUE=medopl

# Tencent Cloud mutations are executed by the Go SDK provisioner.
OPL_TENCENT_PROVISIONER_BIN=/usr/local/bin/opl-tencent-provisioner

# OPL Cloud persistence. Keep the real password outside tracked files.
DATABASE_URL=postgresql://medopl:<replace-with-password>@10.66.0.21:5432/OPLCloud

# Shared only by Control Plane, Fabric, and Ledger. Store it as the
# opl-cloud-internal-service Kubernetes Secret, never in the ConfigMap.
OPL_INTERNAL_SERVICE_TOKEN=<replace-with-32-plus-random-chars>

# Existing Sub2API balance integration. Put both admin values in the
# opl-cloud-sub2api Kubernetes Secret.
OPL_SUB2API_BASE_URL=https://gflabtoken.cn
OPL_SUB2API_ADMIN_EMAIL=<control-plane-admin-email>
OPL_SUB2API_ADMIN_PASSWORD=<control-plane-admin-password>
OPL_SUB2API_SUPPORTED_VERSIONS=0.1.153
OPL_SUB2API_REQUEST_TIMEOUT_MS=5000

# Initial Console login users. Store the real JSON as a secret named
# OPL_CONSOLE_USERS_JSON; it is imported into PostgreSQL on first boot.
OPL_CONSOLE_USERS_JSON=[{"id":"usr-pi-production","email":"pi@medopl.cn","password":"<replace-with-pi-password>","name":"PI","role":"owner","accountId":"pi-production","sub2apiUserId":41},{"id":"usr-admin-production","email":"admin@medopl.cn","password":"<replace-with-admin-password>","name":"Admin","role":"admin","accountId":"admin","sub2apiUserId":42}]

# Strong shared seed used to derive a different AionUI admin password per Workspace.
OPL_AIONUI_ADMIN_PASSWORD_SEED=<replace-with-32-plus-random-chars>

# Monthly entitlement renewal and expiry.
OPL_MONTHLY_BILLING_WORKER_ENABLED=1
OPL_MONTHLY_BILLING_INTERVAL_MS=3600000

# Package-to-Tencent compute mapping. Instance type ids are required. Node pool
# ids are optional; leave empty to discover an OPL-labeled pool or create one.
OPL_BASIC_COMPUTE_INSTANCE_TYPE=SA5.MEDIUM4
OPL_BASIC_COMPUTE_NODE_POOL_ID=
OPL_PRO_COMPUTE_INSTANCE_TYPE=SA5.2XLARGE16
OPL_PRO_COMPUTE_NODE_POOL_ID=

# Optional operator-only aggregate endpoint. Store the real token as a secret.
# Leave empty to disable GET /api/operator/summary.
OPL_OPERATOR_SUMMARY_TOKEN=<generate-random-operator-token>
