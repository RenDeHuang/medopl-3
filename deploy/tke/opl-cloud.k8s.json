                  },
                  {
                    "name": "DATABASE_URL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-database",
                        "key": "DATABASE_URL"
                      }
                    }
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/healthz",
                    "port": 8081
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                },
                "livenessProbe": {
                  "httpGet": {
