    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "opl-cloud-control-plane",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "control-plane"
        }
      },
      "spec": {
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-cloud"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "opl-cloud",
              "app.kubernetes.io/component": "control-plane"
            }
          },
          "spec": {
            "serviceAccountName": "opl-cloud-control-plane",
            "automountServiceAccountToken": false,
            "imagePullSecrets": [
              {
                "name": "tcr-pull-secret"
              }
            ],
            "securityContext": {
              "runAsNonRoot": true,
              "runAsUser": 10001,
              "runAsGroup": 10001,
              "fsGroup": 10001,
              "seccompProfile": {
                "type": "RuntimeDefault"
              }
            },
            "containers": [
              {
                "name": "control-plane",
                "image": "registry.example.com/opl/opl-cloud:2026-07-01",
                "imagePullPolicy": "IfNotPresent",
                "ports": [
                  {
                    "name": "http",
                    "containerPort": 8787
                  }
                ],
                "envFrom": [
                  {
                    "configMapRef": {
                      "name": "opl-cloud-config"
                    }
                  }
                ],
                "env": [
                  {
                    "name": "PGSSLMODE",
                    "value": "disable"
                  },
                  {
                    "name": "DATABASE_URL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-database",
                        "key": "DATABASE_URL"
                      }
                    }
                  },
                  {
                    "name": "OPL_CONSOLE_USERS_JSON",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-auth",
                        "key": "OPL_CONSOLE_USERS_JSON"
                      }
                    }
                  },
                  {
                    "name": "OPL_OPERATOR_SUMMARY_TOKEN",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-operator",
                        "key": "OPL_OPERATOR_SUMMARY_TOKEN",
                        "optional": true
                      }
                    }
                  },
                  {
                    "name": "OPL_AIONUI_ADMIN_PASSWORD_SEED",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-aionui",
                        "key": "OPL_AIONUI_ADMIN_PASSWORD_SEED"
                      }
                    }
                  },
                  {
                    "name": "OPL_CODEX_API_KEY",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-workspace-codex",
                        "key": "OPL_CODEX_API_KEY",
                        "optional": true
                      }
                    }
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/api/production/readiness",
                    "port": 8787
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                },
                "livenessProbe": {
                  "httpGet": {
                    "path": "/api/healthz",
                    "port": 8787
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 20
                },
                "resources": {
                  "requests": {
                    "cpu": "100m",
                    "memory": "256Mi"
                  },
                  "limits": {
                    "cpu": "500m",
                    "memory": "768Mi"
                  }
                },
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "readOnlyRootFilesystem": true,
                  "capabilities": {
                    "drop": [
                      "ALL"
                    ]
                  }
                },
                "volumeMounts": [
                  {
                    "name": "runtime-state",
                    "mountPath": "/app/.runtime"
                  },
                  {
                    "name": "tmp",
                    "mountPath": "/tmp"
                  }
                ]
              }
            ],
            "volumes": [
              {
                "name": "runtime-state",
                "emptyDir": {}
              },
              {
                "name": "tmp",
                "emptyDir": {}
              }
            ]
          }
        }
      }
    },
    {
