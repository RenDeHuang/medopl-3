{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "v1",
      "kind": "Namespace",
      "metadata": {
        "name": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud"
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "ServiceAccount",
      "metadata": {
        "name": "opl-cloud-control-plane",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud"
        }
      },
      "automountServiceAccountToken": false
    },
    {
      "apiVersion": "v1",
      "kind": "ConfigMap",
      "metadata": {
        "name": "opl-cloud-config",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud"
        }
      },
      "data": {
        "NODE_ENV": "production",
        "PORT": "8787",
        "OPL_RUNTIME_PROVIDER": "tencent-tke",
        "OPL_PUBLIC_URL": "https://cloud.medopl.cn",
        "OPL_CONSOLE_DOMAIN": "cloud.medopl.cn",
        "OPL_WORKSPACE_DOMAIN": "workspace.medopl.cn",
        "OPL_CLOUD_IMAGE": "registry.example.com/opl/opl-cloud@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "OPL_WORKSPACE_IMAGE": "registry.example.com/opl/one-person-lab-app@sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
        "OPL_K8S_NAMESPACE": "opl-cloud",
        "OPL_INGRESS_CLASS": "qcloud",
        "OPL_IMAGE_PULL_SECRET_NAME": "tcr-pull-secret",
        "OPL_WORKSPACE_STORAGE_CLASS": "cbs",
        "OPL_WORKSPACE_WEBUI_PORT": "3000",
        "OPL_WORKSPACE_DATA_DIR": "/data",
        "OPL_WORKSPACE_PROJECTS_DIR": "/projects",
        "OPL_CONSOLE_TLS_SECRET_NAME": "opl-cloud-console-medopl-cn-tls",
        "OPL_WORKSPACE_TLS_SECRET_NAME": "opl-cloud-workspace-medopl-cn-tls",
        "TENCENT_DEPLOY_CLUSTER_ID": "cls-xxxxxxxx",
        "TENCENT_TCR_REGISTRY": "registry.example.com",
        "TENCENT_TCR_NAMESPACE": "opl",
        "TENCENT_TCR_REGION": "ap-guangzhou",
        "TENCENT_DEPLOY_KUBECONFIG_REF": "/var/run/opl-cloud/kubeconfig/kubeconfig",
        "OPL_MONTHLY_BILLING_WORKER_ENABLED": "1",
        "OPL_MONTHLY_BILLING_INTERVAL_MS": "3600000",
        "OPL_PROVIDER_RECONCILE_WORKER_ENABLED": "1",
        "OPL_TENCENT_ZONE": "ap-guangzhou-3",
        "OPL_BASIC_COMPUTE_INSTANCE_TYPE": "SA5.MEDIUM4",
        "OPL_PRO_COMPUTE_INSTANCE_TYPE": "SA5.2XLARGE16",
        "OPL_CODEX_MODEL": "gpt-5.5",
        "OPL_CODEX_REASONING_EFFORT": "xhigh",
        "OPL_SUB2API_BASE_URL": "https://gflabtoken.cn",
        "OPL_SUB2API_REQUEST_TIMEOUT_MS": "5000",
        "OPL_TENCENT_PROVISIONER_BIN": "/usr/local/bin/opl-tencent-provisioner",
        "OPL_TENCENT_ZONE": "na-siliconvalley-1",
        "TENCENTCLOUD_REGION": "na-siliconvalley",
        "TENCENT_CVM_SUBNET_ID": "subnet-xxxxxxxx",
        "TENCENT_CVM_SECURITY_GROUP_IDS": "sg-xxxxxxxx",
        "TENCENT_CVM_SYSTEM_DISK_TYPE": "CLOUD_BSSD",
        "TENCENT_CVM_SYSTEM_DISK_SIZE_GB": "50",
        "RUN_TENCENT_CREATE_RELEASE_EXECUTION": "0",
        "LEDGER_URL": "http://opl-cloud-ledger:8081",
        "FABRIC_URL": "http://opl-cloud-fabric:8082"
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "opl-cloud-control-plane",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "control-plane"
        }
      },
      "spec": {
        "replicas": 1,
        "strategy": {
          "type": "Recreate"
        },
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-cloud"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "opl-cloud",
              "app.kubernetes.io/component": "control-plane"
            }
          },
          "spec": {
            "serviceAccountName": "opl-cloud-control-plane",
            "automountServiceAccountToken": false,
            "imagePullSecrets": [
              {
                "name": "tcr-pull-secret"
              }
            ],
            "securityContext": {
              "runAsNonRoot": true,
              "runAsUser": 10001,
              "runAsGroup": 10001,
              "fsGroup": 10001,
              "seccompProfile": {
                "type": "RuntimeDefault"
              }
            },
            "containers": [
              {
                "name": "control-plane",
                "image": "registry.example.com/opl/opl-cloud@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
                "imagePullPolicy": "IfNotPresent",
                "ports": [
                  {
                    "name": "http",
                    "containerPort": 8787
                  }
                ],
                "envFrom": [
                  {
                    "configMapRef": {
                      "name": "opl-cloud-config"
                    }
                  }
                ],
                "env": [
                  {
                    "name": "DATABASE_URL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-database",
                        "key": "DATABASE_URL"
                      }
                    }
                  },
                  {
                    "name": "OPL_INTERNAL_SERVICE_TOKEN",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-internal-service",
                        "key": "OPL_INTERNAL_SERVICE_TOKEN"
                      }
                    }
                  },
                  {
                    "name": "OPL_AIONUI_ADMIN_PASSWORD_SEED",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-aionui",
                        "key": "OPL_AIONUI_ADMIN_PASSWORD_SEED"
                      }
                    }
                  },
                  {
                    "name": "OPL_SUB2API_ADMIN_EMAIL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-sub2api",
                        "key": "OPL_SUB2API_ADMIN_EMAIL"
                      }
                    }
                  },
                  {
                    "name": "OPL_SUB2API_ADMIN_PASSWORD",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-sub2api",
                        "key": "OPL_SUB2API_ADMIN_PASSWORD"
                      }
                    }
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/api/production/readiness",
                    "port": 8787
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                },
                "livenessProbe": {
                  "httpGet": {
                    "path": "/api/healthz",
                    "port": 8787
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 20
                },
                "resources": {
                  "requests": {
                    "cpu": "100m",
                    "memory": "256Mi"
                  },
                  "limits": {
                    "cpu": "500m",
                    "memory": "768Mi"
                  }
                },
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "readOnlyRootFilesystem": true,
                  "capabilities": {
                    "drop": [
                      "ALL"
                    ]
                  }
                },
                "volumeMounts": [
                  {
                    "name": "runtime-state",
                    "mountPath": "/app/.runtime"
                  },
                  {
                    "name": "tmp",
                    "mountPath": "/tmp"
                  }
                ]
              }
            ],
            "volumes": [
              {
                "name": "runtime-state",
                "emptyDir": {}
              },
              {
                "name": "tmp",
                "emptyDir": {}
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "opl-cloud-control-plane",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "control-plane"
        }
      },
      "spec": {
        "type": "NodePort",
        "selector": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "control-plane"
        },
        "ports": [
          {
            "name": "http",
            "port": 8787,
            "targetPort": "http"
          }
        ]
      }
    },
    {
      "apiVersion": "networking.k8s.io/v1",
      "kind": "NetworkPolicy",
      "metadata": {
        "name": "opl-cloud-control-plane-ingress",
        "namespace": "opl-cloud"
      },
      "spec": {
        "podSelector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-cloud",
            "app.kubernetes.io/component": "control-plane"
          }
        },
        "policyTypes": [
          "Ingress"
        ],
        "ingress": [
          {
            "ports": [
              {
                "protocol": "TCP",
                "port": 8787
              }
            ]
          }
        ]
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "opl-cloud-ledger",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "ledger"
        }
      },
      "spec": {
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-cloud",
            "app.kubernetes.io/component": "ledger"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "opl-cloud",
              "app.kubernetes.io/component": "ledger"
            }
          },
          "spec": {
            "serviceAccountName": "opl-cloud-control-plane",
            "automountServiceAccountToken": false,
            "imagePullSecrets": [
              {
                "name": "tcr-pull-secret"
              }
            ],
            "securityContext": {
              "runAsNonRoot": true,
              "runAsUser": 10001,
              "runAsGroup": 10001,
              "fsGroup": 10001,
              "seccompProfile": {
                "type": "RuntimeDefault"
              }
            },
            "containers": [
              {
                "name": "ledger",
                "image": "registry.example.com/opl/opl-cloud@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
                "imagePullPolicy": "Always",
                "ports": [
                  {
                    "name": "ledger",
                    "containerPort": 8081
                  }
                ],
                "envFrom": [
                  {
                    "configMapRef": {
                      "name": "opl-cloud-config"
                    }
                  }
                ],
                "env": [
                  {
                    "name": "DATABASE_URL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-database",
                        "key": "DATABASE_URL"
                      }
                    }
                  },
                  {
                    "name": "OPL_INTERNAL_SERVICE_TOKEN",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-internal-service",
                        "key": "OPL_INTERNAL_SERVICE_TOKEN"
                      }
                    }
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/healthz",
                    "port": 8081
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                },
                "livenessProbe": {
                  "httpGet": {
                    "path": "/healthz",
                    "port": 8081
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 20
                },
                "resources": {
                  "requests": {
                    "cpu": "100m",
                    "memory": "256Mi"
                  },
                  "limits": {
                    "cpu": "500m",
                    "memory": "768Mi"
                  }
                },
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "readOnlyRootFilesystem": true,
                  "capabilities": {
                    "drop": [
                      "ALL"
                    ]
                  }
                },
                "volumeMounts": [],
                "command": [
                  "/usr/local/bin/opl-ledger"
                ]
              }
            ],
            "volumes": []
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "opl-cloud-ledger",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "ledger"
        }
      },
      "spec": {
        "type": "ClusterIP",
        "selector": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "ledger"
        },
        "ports": [
          {
            "name": "ledger",
            "port": 8081,
            "targetPort": "ledger"
          }
        ]
      }
    },
    {
      "apiVersion": "networking.k8s.io/v1",
      "kind": "NetworkPolicy",
      "metadata": {
        "name": "opl-cloud-ledger-ingress",
        "namespace": "opl-cloud"
      },
      "spec": {
        "podSelector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-cloud",
            "app.kubernetes.io/component": "ledger"
          }
        },
        "policyTypes": [
          "Ingress"
        ],
        "ingress": [
          {
            "from": [
              {
                "podSelector": {
                  "matchLabels": {
                    "app.kubernetes.io/name": "opl-cloud",
                    "app.kubernetes.io/component": "control-plane"
                  }
                }
              }
            ],
            "ports": [
              {
                "protocol": "TCP",
                "port": 8081
              }
            ]
          }
        ]
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "opl-cloud-fabric",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "fabric"
        }
      },
      "spec": {
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-cloud",
            "app.kubernetes.io/component": "fabric"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "opl-cloud",
              "app.kubernetes.io/component": "fabric"
            }
          },
          "spec": {
            "serviceAccountName": "opl-cloud-control-plane",
            "automountServiceAccountToken": false,
            "imagePullSecrets": [
              {
                "name": "tcr-pull-secret"
              }
            ],
            "securityContext": {
              "runAsNonRoot": true,
              "runAsUser": 10001,
              "runAsGroup": 10001,
              "fsGroup": 10001,
              "seccompProfile": {
                "type": "RuntimeDefault"
              }
            },
            "containers": [
              {
                "name": "fabric",
                "image": "registry.example.com/opl/opl-cloud@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
                "imagePullPolicy": "IfNotPresent",
                "ports": [
                  {
                    "name": "fabric",
                    "containerPort": 8082
                  }
                ],
                "envFrom": [
                  {
                    "configMapRef": {
                      "name": "opl-cloud-config"
                    }
                  }
                ],
                "env": [
                  {
                    "name": "DATABASE_URL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-database",
                        "key": "DATABASE_URL"
                      }
                    }
                  },
                  {
                    "name": "OPL_INTERNAL_SERVICE_TOKEN",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-internal-service",
                        "key": "OPL_INTERNAL_SERVICE_TOKEN"
                      }
                    }
                  },
                  {
                    "name": "TENCENTCLOUD_SECRET_ID",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-tencent-mutation",
                        "key": "TENCENTCLOUD_SECRET_ID"
                      }
                    }
                  },
                  {
                    "name": "TENCENTCLOUD_SECRET_KEY",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-tencent-mutation",
                        "key": "TENCENTCLOUD_SECRET_KEY"
                      }
                    }
                  },
                  {
                    "name": "OPL_AIONUI_ADMIN_PASSWORD_SEED",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-cloud-aionui",
                        "key": "OPL_AIONUI_ADMIN_PASSWORD_SEED"
                      }
                    }
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/healthz",
                    "port": 8082
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                },
                "livenessProbe": {
                  "httpGet": {
                    "path": "/healthz",
                    "port": 8082
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 20
                },
                "resources": {
                  "requests": {
                    "cpu": "100m",
                    "memory": "256Mi"
                  },
                  "limits": {
                    "cpu": "500m",
                    "memory": "768Mi"
                  }
                },
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "readOnlyRootFilesystem": true,
                  "capabilities": {
                    "drop": [
                      "ALL"
                    ]
                  }
                },
                "volumeMounts": [
                  {
                    "name": "deploy-kubeconfig",
                    "mountPath": "/var/run/opl-cloud/kubeconfig",
                    "readOnly": true
                  }
                ],
                "command": [
                  "/usr/local/bin/opl-fabric"
                ]
              }
            ],
            "volumes": [
              {
                "name": "deploy-kubeconfig",
                "secret": {
                  "secretName": "opl-cloud-deploy-kubeconfig"
                }
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "opl-cloud-fabric",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "fabric"
        }
      },
      "spec": {
        "type": "ClusterIP",
        "selector": {
          "app.kubernetes.io/name": "opl-cloud",
          "app.kubernetes.io/component": "fabric"
        },
        "ports": [
          {
            "name": "fabric",
            "port": 8082,
            "targetPort": "fabric"
          }
        ]
      }
    },
    {
      "apiVersion": "networking.k8s.io/v1",
      "kind": "NetworkPolicy",
      "metadata": {
        "name": "opl-cloud-fabric-ingress",
        "namespace": "opl-cloud"
      },
      "spec": {
        "podSelector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-cloud",
            "app.kubernetes.io/component": "fabric"
          }
        },
        "policyTypes": [
          "Ingress"
        ],
        "ingress": [
          {
            "from": [
              {
                "podSelector": {
                  "matchLabels": {
                    "app.kubernetes.io/name": "opl-cloud",
                    "app.kubernetes.io/component": "control-plane"
                  }
                }
              }
            ],
            "ports": [
              {
                "protocol": "TCP",
                "port": 8082
              }
            ]
          }
        ]
      }
    },
    {
      "apiVersion": "cloud.tencent.com/v1alpha1",
      "kind": "TkeServiceConfig",
      "metadata": {
        "name": "opl-cloud-ingress-config",
        "namespace": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-cloud"
        }
      },
      "spec": {
        "loadBalancer": {
          "l7Listeners": [
            {
              "protocol": "HTTPS",
              "port": 443,
              "domains": [
                {
                  "domain": "workspace.medopl.cn",
                  "http2": false,
                  "rules": [
                    {
                      "url": "/",
                      "forwardType": "HTTP"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    {
      "apiVersion": "networking.k8s.io/v1",
      "kind": "Ingress",
      "metadata": {
        "name": "opl-cloud",
        "namespace": "opl-cloud",
        "annotations": {
          "ingress.cloud.tencent.com/listen-ports": "[{\"HTTP\":80},{\"HTTPS\":443}]",
          "ingress.cloud.tencent.com/auto-rewrite": "true",
          "ingress.cloud.tencent.com/direct-access": "true",
          "ingress.cloud.tencent.com/rewrite-support": "true",
          "ingress.cloud.tencent.com/tke-service-config": "opl-cloud-ingress-config"
        }
      },
      "spec": {
        "ingressClassName": "qcloud",
        "tls": [
          {
            "hosts": [
              "cloud.medopl.cn"
            ],
            "secretName": "opl-cloud-console-medopl-cn-tls"
          },
          {
            "hosts": [
              "workspace.medopl.cn"
            ],
            "secretName": "opl-cloud-workspace-medopl-cn-tls"
          }
        ],
        "rules": [
          {
            "host": "cloud.medopl.cn",
            "http": {
              "paths": [
                {
                  "path": "/",
                  "pathType": "Prefix",
                  "backend": {
                    "service": {
                      "name": "opl-cloud-control-plane",
                      "port": {
                        "number": 8787
                      }
                    }
                  }
                }
              ]
            }
          },
          {
            "host": "workspace.medopl.cn",
            "http": {
              "paths": [
                {
                  "path": "/",
                  "pathType": "Prefix",
                  "backend": {
                    "service": {
                      "name": "opl-cloud-control-plane",
                      "port": {
                        "number": 8787
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
