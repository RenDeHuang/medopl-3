                },
                "resources": {
                  "requests": {
                    "cpu": "100m",
                    "memory": "256Mi"
                  },
                  "limits": {
                    "cpu": "500m",
                    "memory": "768Mi"
                  }
                },
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "readOnlyRootFilesystem": true,
                  "capabilities": {
                    "drop": [
                      "ALL"
                    ]
                  }
                },
                "volumeMounts": [],
                "command": [
                  "/usr/local/bin/opl-ledger"
                ]
              }
            ],
            "volumes": []
          }
        }
      }
