# OPL Console local-to-staging environment template.
#
# Copy this file to the ignored repo-root file `.env.staging.local`.
# Do not commit real Tencent Cloud keys, database passwords, kubeconfig paths,
# operator tokens, or auth seed passwords.

OPL_RUNTIME_PROVIDER=tencent-tke
PORT=8787
OPL_PUBLIC_URL=http://127.0.0.1:8787

# Shared staging persistence. Local-to-staging and cloud-staging must use the
# same PostgreSQL database so account mappings, resources, entitlements,
# receipts, and Workspace URLs are one system.
DATABASE_URL=postgresql://opl:<replace-with-staging-password>@<staging-db-host>:5432/OPLCloud?sslmode=verify-full
OPL_INTERNAL_SERVICE_TOKEN=<replace-with-staging-internal-token>

# Workspace runtime.
OPL_WORKSPACE_IMAGE=<tcr-registry>/<tcr-namespace>/one-person-lab-app@sha256:<64-hex-digest>
OPL_WORKSPACE_DOMAIN=workspace.medopl.cn
OPL_WORKSPACE_WEBUI_PORT=3000
OPL_WORKSPACE_DATA_DIR=/data
OPL_WORKSPACE_PROJECTS_DIR=/projects

# Kubernetes/TKE target.
OPL_K8S_NAMESPACE=opl-cloud
OPL_INGRESS_CLASS=qcloud
OPL_WORKSPACE_STORAGE_CLASS=cbs
OPL_IMAGE_PULL_SECRET_NAME=tcr-pull-secret
TENCENT_DEPLOY_KUBECONFIG_REF=/home/dev/.secrets/medopl/v22/kubeconfig-package-d-deploy
TENCENT_DEPLOY_CLUSTER_ID=<staging-tke-cluster-id>

# Tencent Cloud Go SDK provisioner.
OPL_TENCENT_PROVISIONER_BIN=.runtime/opl-tencent-provisioner
OPL_TENCENT_ZONE=na-siliconvalley-1
TENCENTCLOUD_SECRET_ID=<cam-secret-id>
TENCENTCLOUD_SECRET_KEY=<cam-secret-key>
TENCENTCLOUD_REGION=na-siliconvalley

# Native TKE node pool backing for package-level ComputePools.
TENCENT_CVM_SUBNET_ID=<subnet-id>
TENCENT_CVM_SECURITY_GROUP_IDS=<security-group-id>
TENCENT_CVM_SYSTEM_DISK_TYPE=CLOUD_BSSD
TENCENT_CVM_SYSTEM_DISK_SIZE_GB=50

# Sub2API balance and monthly entitlement orchestration.
OPL_SUB2API_BASE_URL=https://gflabtoken.cn
OPL_SUB2API_ADMIN_EMAIL=<control-plane-admin-email>
OPL_SUB2API_ADMIN_PASSWORD=<control-plane-admin-password>
OPL_SUB2API_REQUEST_TIMEOUT_MS=5000
OPL_MONTHLY_BILLING_WORKER_ENABLED=1
OPL_MONTHLY_BILLING_INTERVAL_MS=3600000

# Monthly preflight discovers exactly one OPL-labeled node pool matching the
# package and instance type. Example instance types are cloud SKUs.
OPL_TENCENT_ZONE=<compute-launch-zone>
OPL_BASIC_COMPUTE_INSTANCE_TYPE=SA5.MEDIUM4
OPL_PRO_COMPUTE_INSTANCE_TYPE=SA5.2XLARGE16

OPL_AIONUI_ADMIN_PASSWORD_SEED=<replace-with-32-plus-random-chars>

# Real resource E2E guard. Keep 0 for readiness/local UI. Set to 1 only in an
# operator shell when you intend to create and clean up real Tencent resources.
OPL_CONFIRM_REAL_CLOUD_E2E=0
OPL_VERIFY_ACCOUNT_ID=pi-staging
OPL_VERIFY_OPERATOR_TOKEN=
