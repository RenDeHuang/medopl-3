{
  "name": "one-person-lab-cloud-implementation",
  "version": "0.1.0",
  "private": true,
  "description": "OPL Cloud implementation workspace for OPL Console and OPL Workspace control plane.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "staging:local": "node tools/start-staging-local-api.ts",
    "staging:ui": "node tools/start-staging-local-ui.ts",
    "staging:readiness": "node tools/staging-readiness.ts",
    "staging:e2e": "node tools/staging-local-verifier.ts",
    "start": "cd services/control-plane && go run ./cmd/control-plane",
    "test": "node --test \"tests/**/*.test.ts\"",
    "typecheck": "vue-tsc -p apps/console-ui/tsconfig.json --noEmit",
    "lint": "vue-tsc -p apps/console-ui/tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
    "build": "vite build",
    "verify:production": "node tools/production-verifier.ts",
    "validate:production-manifest": "node tools/validate-production-manifest.ts"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue": "^3.5.18"
  },
  "overrides": {
    "path-to-regexp": "^8.4.0"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "vue-tsc": "^3.0.4",
    "yaml": "^2.9.0"
  }
}
