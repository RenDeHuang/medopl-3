{
  "schemaVersion": 3,
  "owner": "OPL Cloud",
  "purpose": "Product layer, Workspace mapping, access, package, Fabric catalog, and production handoff contract.",
  "state": "current",
  "machineBoundary": "Cloud product resource mapping, URL access mode, package availability, and production handoff rules.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "product": "OPL Cloud",
  "layers": {
    "gateway": "OPL Gateway",
    "workspace": "OPL Workspace",
    "console": "OPL Console",
    "fabric": "OPL Fabric",
    "ledger": "OPL Ledger"
  },
  "console": "OPL Console",
  "workspace": "OPL Workspace",
  "resourceMapping": {
    "workspaceUrlEntry": 1,
    "computeAllocation": 1,
    "storageVolume": 1,
    "storageAttachment": 1,
    "runtimeTemplate": 1,
    "runtimeImageRef": "default:one-person-lab-app"
  },
  "runtimeTemplatePolicy": {
    "defaultTemplateId": "one-person-lab-app",
    "billingObject": false,
    "ownershipRule": "Runtime templates never own accounts, compute allocations, storage volumes, storage attachments, Workspace URL entries, monthly entitlements, charges, or lifecycle records."
  },
  "workspaceEntitlementRule": "Workspace is the customer subscription; compute and storage are provider/compatibility components of one accepted Workspace price and period.",
  "pilotBoundary": {
    "inviteOnly": true,
    "workspaceCardinality": "many_per_account",
    "independentPerWorkspaceFacts": ["quote", "launchOperation", "compute", "storage", "attachment", "runtime", "workspaceApiKeyId", "gatewaySecretRef", "paidThrough", "renewalStatus", "purchaseReceiptId"],
    "workspaceDataAuthority": "cbs",
    "platformStoresWorkspaceFileBodies": false,
    "unsupportedCustomerCapabilities": ["backup", "recovery", "sync", "transfer"],
    "autoRenewDefault": false,
    "autoRenewCustomerControl": "hidden_until_real_renewal_evidence",
    "unpaidExpiry": "deny_access_zero_fabric_or_tencent_mutation_expire_by_provider"
  },
  "publicEntryPoints": {
    "homeLoginLogo": "unchanged",
    "regressionRequired": ["desktop", "mobile"]
  },
  "access": {
    "urlPattern": "https://workspace.medopl.cn/w/<workspaceId>/",
    "mode": "runtime_password",
    "requiresLogin": true,
    "workspaceQuestions": ["url", "username", "passwordRevealCopy", "workspaceKeyRevealCopy"]
  },
  "workspaceRuntimeFacts": {
    "launchStatus": "paused_not_in_release",
    "fileMetadataAuthority": "workspace_runtime_projects_mount",
    "filesystemUsageAuthority": "workspace_runtime_statfs",
    "apiRoutes": [],
    "consolePresentation": "absent",
    "persistence": "none",
    "releaseValidation": "direct_runtime_pod_sha256_markers_only"
  },
  "defaultPackages": [
    {
      "id": "basic",
      "name": "Basic Workspace",
      "accelerator": "cpu",
      "cpu": 2,
      "memoryGb": 4,
      "gpu": 0,
      "server": "2c4g",
      "diskGb": 10,
      "targetPackage": true
    },
    {
      "id": "pro",
      "name": "Pro Workspace",
      "accelerator": "cpu",
      "cpu": 8,
      "memoryGb": 16,
      "gpu": 0,
      "server": "8c16g",
      "diskGb": 100,
      "targetPackage": true
    }
  ],
  "fabricResourceCatalog": {
    "contract": "packages/contracts/opl-cloud-fabric-resource-catalog-contract.json",
    "runtimeReadinessField": "resourceCatalog",
    "consoleSelectableRule": "workspace package must be available=true"
  },
  "productionHandoff": {
    "manifestExample": "deploy/production-manifest.example.json",
    "validateCommand": "npm run validate:production-manifest -- --manifest <manifest.json>",
    "secretPolicy": "sensitive_values_must_use_secretRef"
  },
  "nonGoals": [
    "member_login_for_shared_urls",
    "workspace_owned_compute_or_storage_lifecycle",
    "local_development_requires_kubernetes",
    "external_payment_processing",
    "live_tencent_price_lookup_before_each_resource_create"
  ]
}
