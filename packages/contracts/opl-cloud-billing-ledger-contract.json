{
  "schemaVersion": 10,
  "owner": "OPL Control Plane",
  "purpose": "One-charge Workspace purchase and renewal, fulfillment, entitlement, receipt, wallet-adjustment reference, and reconciliation ownership contract.",
  "state": "current",
  "machineBoundary": "Sub2API owns spendable USD balance; Control Plane owns the single Workspace charge operation and monthly entitlement; Fabric owns provider fulfillment; Ledger owns append-only evidence receipts and reconciliation reports.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same ownership boundary."
  },
  "billingUnit": "calendar_month",
  "priceBasis": "opl_monthly_resource_catalog",
  "providerCostBasis": "internal_evidence_only",
  "balanceOwner": "sub2api",
  "balanceReadApis": [
    "GET /api/v1/admin/users/:id"
  ],
  "moneyWriteApis": [
    "POST /api/v1/admin/redeem-codes/create-and-redeem"
  ],
  "chargePolicy": {
    "customerObject": "workspace",
    "launchOperationAction": "workspace.launch.v2",
    "launchOperationSchemaVersion": 2,
    "debitCardinalityPerPeriod": 1,
    "currency": "USD",
    "unit": "usd_micros",
    "writeType": "negative_redeem_code",
    "idempotencyIdentity": "opl:<environment>:<billing-operation-id>:charge:v1",
    "walletMutationSerializationContract": "opl-cloud-service-boundary-contract.json#services.controlPlane.walletMutationSerialization",
    "exactBalanceEvidence": {
      "precondition": "preBalanceUsdMicros > totalChargeUsdMicros",
      "postcondition": "postBalanceUsdMicros == preBalanceUsdMicros - totalChargeUsdMicros",
      "mismatchStatus": "manual_review",
      "fabricWriteCountOnMismatch": 0
    },
    "providerPreflight": {
      "timing": "before_first_charge_attempt",
      "runWhen": "ChargeAttempted=false_and_ChargeConfirmation_absent",
      "skipOnRecoveryWhenAnyPresent": ["ChargeAttempted", "ChargeConfirmation"],
      "writes": "none"
    },
    "activationRule": "Grant or extend entitlement only after the redeem record, post-charge balance, provider resources, attachment, Secret, and Runtime readiness are confirmed.",
    "ambiguousResult": "manual_review",
    "automaticPositiveAdjustment": false
  },
  "workspaceLaunchFulfillment": {
    "customerChargeOperations": ["workspace_debit", "workspace_refund"],
    "resourcePurchasePath": "fabric_create_and_sync_without_customer_debit",
    "providerMutationOwner": "fabric",
    "successReceiptType": "billing.workspace_purchased.v1",
    "refundReceiptType": "billing.workspace_refunded.v1",
    "confirmedNoResource": "one_idempotent_workspace_refund",
    "partialOrUnknownResource": "manual_review_without_refund",
    "ledgerFailureAfterActivation": "retry_receipt_only",
    "activationReadback": {
      "apis": ["SyncMonthlyCompute", "SyncMonthlyStorage"],
      "timing": "immediately_before_workspace_activation",
      "sharedRequiredFacts": ["resource_identity", "account_identity", "workspace_identity", "zone", "chargeType=PREPAID", "renewFlag=NOTIFY_AND_MANUAL_RENEW", "deadline"],
      "computeRequiredFacts": ["sku"],
      "storageRequiredFacts": ["capacity"],
      "mismatch": "manual_review_without_activation"
    },
    "manualReviewRecoveryContract": "opl-cloud-launch-freeze-contract.json#workspaceLaunch.manualReviewRecovery",
    "implementation": "non_review_path_local_tests_manual_review_recovery_pending_integration_verification",
    "realEnvironmentEvidence": "pending_owner_approved_acceptance"
  },
  "walletAdjustmentEvidence": {
    "kinds": ["recharge", "debit", "business_refund"],
    "balanceAuthority": "sub2api",
    "moneyWriteApi": "POST /api/v1/admin/redeem-codes/create-and-redeem",
    "authoritativeReadback": ["sub2api_balance_history", "sub2api_user_balance"],
    "controlPlaneState": "runtime_operation_non_authoritative",
    "ledgerState": "append_only_reference_non_authoritative",
    "localBalancePersistence": false,
    "redeemCode": {
      "version": "v2",
      "format": "\"opl:\" + stableID(\"sub2api-wallet-adjustment-v2\", operationID)[:28]",
      "length": 32,
      "pattern": "^opl:[0-9a-f]{28}$",
      "legacyV1Length": 49,
      "legacyV1Policy": "read_only_history_identity_never_payload_or_idempotency_key"
    },
    "manualReviewRecovery": "explicit_operator_original_operation_v2_supersession_maximum_one_money_write",
    "upstreamFailureFields": ["phase", "httpStatus", "errorCode", "requestId"],
    "rawUpstreamResponsePersistence": false
  },
  "entitlementPolicy": {
    "owner": "opl-control-plane",
    "customerRenewalAuthority": "workspace",
    "workspaceCustomerFields": [
      "priceVersion",
      "currency",
      "totalUsdMicros",
      "periodStart",
      "paidThrough",
      "autoRenew",
      "renewalStatus"
    ],
    "resourceCompatibility": {
      "renewalIntentAuthority": false,
      "customerPricingAuthority": false,
      "customerChargeOwner": false,
      "customerSurface": "workspace_detail_read_only"
    },
    "resourceCompatibilityFields": [
      "billingStatus",
      "billingOperationId",
      "pricingVersion",
      "monthlyPriceCnyCents",
      "chargeUsdMicros",
      "periodStart",
      "paidThrough",
      "autoRenew"
    ],
    "resourceCompatibilityFieldsStatus": "historical_rows_only",
    "newWorkspaceFulfillmentCustomerBillingFields": [],
    "newWorkspaceFulfillmentForbiddenFields": [
      "billingOperationId",
      "billingStatus",
      "priceVersion",
      "chargeUsdMicros",
      "periodStart",
      "paidThrough"
    ],
    "computeExpiry": "destroy_and_deny_access",
    "storageExpiry": "retain_and_deny_access"
  },
  "ledgerEvidencePolicy": {
    "owner": "opl-ledger",
    "recordApi": "POST /ledger/receipts",
    "resourceReceiptSchemaStatus": "superseded_internal_compatibility",
    "receiptTypes": [
      "billing.resource_purchased.v1",
      "billing.resource_renewed.v1",
      "billing.resource_expired.v1",
      "billing.resource_refunded.v1",
      "billing.charge_review_required.v1",
      "billing.reconciliation.v1",
      "billing.workspace_purchased.v1",
      "billing.workspace_renewed.v1",
      "billing.workspace_expired.v1",
      "billing.workspace_refunded.v1",
      "gateway.wallet_adjustment.v1",
      "workspace.gateway_key_rotated.v1"
    ],
    "requiredCostFields": [
      "pricingVersion",
      "monthlyPriceCnyCents",
      "chargeUsdMicros",
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "periodStart",
      "paidThrough",
      "resourceType",
      "resourceId"
    ],
    "costFieldTypes": {
      "pricingVersion": "non_empty_opaque_string",
      "monthlyPriceCnyCents": "non_negative_integer",
      "chargeUsdMicros": "non_negative_integer",
      "sub2apiUserId": "positive_integer",
      "sub2apiRedeemCode": "non_empty_opaque_string",
      "periodStart": "RFC3339_string",
      "paidThrough": "RFC3339_string",
      "resourceType": "non_empty_opaque_string",
      "resourceId": "non_empty_opaque_string"
    },
    "workspaceReceiptTypes": {
      "purchased": "billing.workspace_purchased.v1",
      "renewed": "billing.workspace_renewed.v1",
      "expired": "billing.workspace_expired.v1",
      "refunded": "billing.workspace_refunded.v1"
    },
    "workspaceFulfillmentReceiptTypes": [
      "billing.workspace_purchased.v1",
      "billing.workspace_renewed.v1"
    ],
    "workspaceRequiredCostFields": [
      "priceVersion",
      "currency",
      "billingUnit",
      "totalUsdMicros",
      "periodStart",
      "paidThrough",
      "resourceType",
      "resourceId",
      "components"
    ],
    "workspacePurchasedAdditionalCostFields": [
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "postChargeBalanceUsdMicros"
    ],
    "workspaceRenewedAdditionalCostFields": [
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "postChargeBalanceUsdMicros"
    ],
    "workspaceRefundedAdditionalCostFields": [
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "sub2apiRefundCode",
      "refundUsdMicros"
    ],
    "workspaceCostRules": {
      "currency": "USD",
      "billingUnit": "calendar_month",
      "resourceType": "workspace",
      "outerWorkspaceIdentity": "cost.resourceId_equals_receipt.workspaceId",
      "components": ["compute", "storage"],
      "componentAmounts": "positive_integer_usd_micros",
      "storageSizeGb": "positive_integer",
      "total": "compute.chargeUsdMicros + storage.chargeUsdMicros with int64 overflow rejection",
      "period": "paidThrough RFC3339 is strictly after periodStart RFC3339",
      "expiredReceiptHasNoSyntheticCharge": true,
      "refundedAmount": "refundUsdMicros equals totalUsdMicros"
    },
    "forbiddenContentRule": "reject recursively by case-insensitive exact field name in maps, slices, and typed JSON containers; token-count fields such as inputTokens remain allowed",
    "forbiddenContent": [
      "apiKey",
      "adminToken",
      "rawSub2apiResponse",
      "rawProviderResponse",
      "password",
      "token"
    ],
    "implementation": "workspace_purchase_validator_writer_and_projection_code_complete_local_tests_only",
    "realEnvironmentEvidence": "pending_owner_approved_acceptance"
  },
  "reconciliationPolicy": {
    "owner": "opl-ledger",
    "recordApi": "POST /ledger/reconciliation",
    "exceptionOnly": true,
    "mayBlockNewPurchases": true,
    "requestUsageCopied": false,
    "idempotencyKey": "required_non_blank",
    "requiredReportFields": ["id", "status", "counts", "exceptions"],
    "statuses": ["ok", "mismatch"],
    "counts": {
      "requiredFields": ["billingOperations", "matched", "exceptions"],
      "allFields": "non_negative_integer"
    },
    "exceptions": {
      "type": "array",
      "requiredFields": ["resourceType", "resourceId", "code"],
      "resourceTypes": ["compute", "storage", "workspace"],
      "resourceId": "non_empty_opaque_string",
      "codes": [
        "billing_operation_invalid",
        "sub2api_balance_history_unavailable",
        "sub2api_charge_missing",
        "sub2api_charge_mismatch",
        "fabric_operations_unavailable",
        "fabric_operation_missing",
        "fabric_operation_mismatch",
        "ledger_receipts_unavailable",
        "ledger_receipt_missing",
        "ledger_receipt_mismatch"
      ]
    },
    "workspaceRenewalAuthority": {
      "customerOperationCardinality": 1,
      "balanceFact": "one_combined_sub2api_charge",
      "providerFacts": ["compute_renewal", "storage_renewal"],
      "receiptType": "billing.workspace_renewed.v1"
    },
    "consistencyRules": [
      "counts.exceptions equals exceptions length",
      "counts.billingOperations equals counts.matched plus unique exception resource count",
      "ok has zero exceptions and does not block new Workspaces",
      "mismatch has at least one exception and blocks new Workspaces"
    ],
    "result": {
      "identity": "id and status equal the submitted report",
      "report": "structurally_equal_to_submitted_report",
      "blockNewWorkspaces": "status_equals_mismatch",
      "reason": "operator_reconciliation"
    },
    "validationOrder": "validate before hash, idempotency lookup, or persistence",
    "replayRule": "validate persisted report and result guard before return",
    "forbiddenContentRule": "same recursive case-insensitive exact-field rule as billing receipts"
  }
}
