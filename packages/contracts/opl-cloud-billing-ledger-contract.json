{
  "schemaVersion": 1,
  "owner": "OPL Ledger",
  "purpose": "Commercial resource leasing ledger, wallet transaction, resource usage debit, hold, top-up, and reconciliation policy.",
  "state": "current",
  "machineBoundary": "Ledger entries, wallet transactions, manual top-up audits, resource usage logs, resource usage rollups, and billing reconciliation guards. Request-level product billing is owned outside OPL Cloud.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "billingUnit": "hour",
  "priceBasis": "opl_user_price_catalog",
  "providerCostBasis": "internal_estimate_only",
  "ledgerEntryTypes": [
    "credit",
    "compute_hold",
    "storage_hold",
    "compute_debit",
    "storage_debit",
    "compute_hold_released",
    "storage_hold_released",
    "compute_hold_exhausted",
    "token_reset",
    "token_deleted",
    "wallet_transaction",
    "manual_topup"
  ],
  "requiredFields": [
    "id",
    "workspaceId",
    "type",
    "amount",
    "currency",
    "sourceEventId",
    "createdAt"
  ],
  "prepaidHoldPolicy": {
    "days": 7,
    "resources": [
      "compute",
      "storage"
    ],
    "chargeOrder": [
      "available_balance",
      "resource_hold"
    ],
    "requiredBefore": [
      "create_compute_allocation",
      "create_storage_volume"
    ],
    "unpaidComputeOperationAllowed": false,
    "unpaidStorageOperationAllowed": false
  },
  "ledgerEvidencePolicy": {
    "priceSnapshotFields": [
      "priceBasis",
      "userPrice",
      "providerCostEstimate"
    ],
    "resourceOwnerFields": [
      "ownerAccountId",
      "ownerUserId",
      "computeAllocationId",
      "storageId",
      "attachmentId",
      "workspaceIds",
      "nodePoolId",
      "cvmInstanceId",
      "nodeName",
      "privateIp",
      "publicIp"
    ],
    "rules": [
      "Customer debits use final OPL user prices only.",
      "Provider cost estimates are stored for internal reconciliation and never as the user billing formula.",
      "Every resource hold, debit, release, and destroy evidence entry must be attributable to an owner and resource identity."
    ]
  },
  "tencentBillReconciliation": {
    "command": "npm run reconcile:tencent -- --ledger <ledger.json> --tencent <tencent-bills.json>",
    "defaultToleranceCny": 0.01,
    "ledgerUsageTypes": [
      "compute_debit",
      "storage_debit"
    ],
    "tencentBillFields": [
      "workspaceId",
      "resourceType",
      "amount",
      "currency"
    ],
    "rawTencentExport": {
      "supported": true,
      "requiredWorkspaceTag": "workspace_id",
      "cliFlag": "--tencent-format raw"
    },
    "resourceTypes": [
      "compute_allocation",
      "storage_volume"
    ],
    "guard": {
      "storedIn": "billing_reconciliation_reports",
      "blocks": [
        "create_compute_allocation",
        "create_storage_volume"
      ],
      "doesNotBlock": [
        "resolve_workspace_access",
        "settle_billing",
        "destroy_compute",
        "destroy_storage"
      ],
      "blockReasons": [
        "tencent_bill_reconciliation_failed",
        "billing_reconciliation_report_missing",
        "billing_reconciliation_report_stale"
      ],
      "operatorNotificationType": "billing.reconciliation_guard_blocked"
    }
  },
  "walletPolicy": {
    "billingTruth": "users",
    "balanceFields": [
      "balance",
      "frozen",
      "holds",
      "totalRecharged"
    ],
    "mutationRecords": [
      "walletTransactions",
      "manualTopups",
      "billingLedger"
    ],
    "compatibilityMirrorsAllowed": false
  }
}
