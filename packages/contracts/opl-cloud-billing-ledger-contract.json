{
  "schemaVersion": 2,
  "owner": "OPL Control Plane",
  "purpose": "Monthly resource charge, entitlement, receipt, and reconciliation ownership contract.",
  "state": "current",
  "machineBoundary": "Sub2API owns spendable USD balance; Control Plane owns resource charge operations and monthly entitlement; Ledger owns append-only evidence receipts and reconciliation reports.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same ownership boundary."
  },
  "billingUnit": "calendar_month",
  "priceBasis": "opl_monthly_resource_catalog",
  "providerCostBasis": "internal_evidence_only",
  "balanceOwner": "sub2api",
  "balanceReadApis": [
    "GET /api/v1/admin/users/:id"
  ],
  "moneyWriteApis": [
    "POST /api/v1/admin/redeem-codes/create-and-redeem"
  ],
  "chargePolicy": {
    "currency": "USD",
    "unit": "usd_micros",
    "writeType": "negative_redeem_code",
    "idempotencyIdentity": "opl:<environment>:<billing-operation-id>:charge:v1",
    "activationRule": "Grant or extend entitlement only after the redeem record and post-charge balance are confirmed.",
    "ambiguousResult": "manual_review",
    "automaticPositiveAdjustment": false
  },
  "entitlementPolicy": {
    "owner": "opl-control-plane",
    "requiredFields": [
      "billingStatus",
      "billingOperationId",
      "pricingVersion",
      "monthlyPriceCnyCents",
      "chargeUsdMicros",
      "periodStart",
      "paidThrough",
      "autoRenew"
    ],
    "computeExpiry": "destroy_and_deny_access",
    "storageExpiry": "retain_and_deny_access"
  },
  "ledgerEvidencePolicy": {
    "owner": "opl-ledger",
    "recordApi": "POST /ledger/receipts",
    "receiptTypes": [
      "billing.resource_purchased.v1",
      "billing.resource_renewed.v1",
      "billing.resource_expired.v1",
      "billing.resource_refunded.v1",
      "billing.charge_review_required.v1",
      "billing.reconciliation.v1"
    ],
    "requiredCostFields": [
      "pricingVersion",
      "monthlyPriceCnyCents",
      "chargeUsdMicros",
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "periodStart",
      "paidThrough",
      "resourceType",
      "resourceId"
    ],
    "forbiddenContent": [
      "apiKey",
      "adminToken",
      "password",
      "rawSub2apiResponse"
    ]
  },
  "reconciliationPolicy": {
    "owner": "opl-ledger",
    "exceptionOnly": true,
    "mayBlockNewPurchases": true,
    "requestUsageCopied": false
  }
}
