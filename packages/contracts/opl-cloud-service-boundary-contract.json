{
  "schemaVersion": 11,
  "owner": "OPL Platform Architecture",
  "purpose": "Current ownership contract for Console UI, Control Plane, Ledger, Fabric, and external Sub2API.",
  "state": "current",
  "machineBoundary": "Service ownership, persistence, cloud SDK ownership, live customer fact projection, Sub2API balance access, and evidence rules.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current service-boundary contract."
  },
  "services": {
    "consoleUi": {
      "path": "apps/console-ui",
      "language": "typescript",
      "framework": "vue",
      "persistence": "none",
      "calls": {
        "controlPlane": "http"
      }
    },
    "controlPlane": {
      "path": "services/control-plane",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "sessions",
        "announcements",
        "announcementReads",
        "accountMappings",
        "internalOneToOneIdentityCompatibilityRecords",
        "workspaces",
        "monthlyEntitlements",
        "billingOperations",
        "latestReconciliationGuard",
        "supportTicketMappings",
        "operationRequests"
      ],
      "legacyInertPhysicalTables": {
        "workspace_backups": {
          "state": "legacy_inert",
          "runtimeAccess": false,
          "dropRequiresSeparateApprovedMigration": true
        },
        "control_plane_workspace_sync_events": {
          "state": "legacy_inert",
          "runtimeAccess": false,
          "dropRequiresSeparateApprovedMigration": true
        },
        "control_plane_project_task_sync_heads": {
          "state": "legacy_inert",
          "runtimeAccess": false,
          "dropRequiresSeparateApprovedMigration": true
        },
        "control_plane_execution_requests": {
          "state": "legacy_inert",
          "runtimeAccess": false,
          "dropRequiresSeparateApprovedMigration": true
        }
      },
      "calls": {
        "ledger": "http",
        "fabric": "http",
        "sub2api": "http"
      },
      "ephemeralOnly": ["sessionDelegatedGatewayCredential"],
      "sessionDelegatedGatewayCredential": {
        "source": "sub2api_user_login",
        "persistence": "process_memory_only",
        "lookupKey": "hashed_console_session_key",
        "lifetime": "console_session_or_shorter",
        "horizontalScaling": "forbidden_until_secure_shared_vault_is_approved"
      },
      "operatorProjection": {
        "authorities": ["control_plane", "sub2api", "fabric", "ledger", "runtime"],
        "persistence": "none_request_join_only",
        "controlPlanePaginationFirst": true,
        "pageSizeDefault": 20,
        "pageSizeMax": 50,
        "sub2apiStrategy": "current_control_plane_page_exact_user_id_reads_and_batch_aggregates",
        "userAndBalanceRead": "current_page_exact_id_bounded_concurrency_max_4",
        "usageRead": "current_page_user_ids_batch_required",
        "workspaceCountRead": "single_control_plane_group_by_for_current_page",
        "scaleInvariant": "same_page_size_request_count_equal_for_100_and_1000_accounts",
        "fabricStrategy": "current_workspace_page_only_batch_provider_facts",
        "runtimeStrategy": "bounded_concurrency_independent_timeout",
        "missingOwnerFact": "source_unavailable_without_zero_or_fallback",
        "readReplica": false
      },
      "accountOwnerAuthorization": {
        "authority": "active_account_owner_graph",
        "reservedAdminOwnerAccount": "acct-admin",
        "operatorCapabilityDoesNotGrantCrossAccountOwnership": true
      },
      "walletMutationSerialization": {
        "deployment": "single_control_plane_replica",
        "scope": "process_local",
        "primitive": "lockResource(\"sub2api-wallet\", accountId)",
        "operations": ["operator_wallet_adjustment", "workspace.launch.v2_debit", "workspace.launch.v2_refund", "workspace_renewal_debit", "workspace_renewal_refund"],
        "additionalLockService": false,
        "multiReplicaPolicy": "forbidden_until_approved_distributed_serialization"
      },
      "forbiddenPersistence": ["gatewayCredentials", "apiKeys", "apiUsage", "walletBalances", "runtimeFileMetadata"]
    },
    "ledger": {
      "path": "services/ledger",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "evidenceReceipts",
        "artifactManifests",
        "reviewResults",
        "reviewPolicies",
        "continuations",
        "auditEvents",
        "idempotencyKeys",
        "reconciliationReports"
      ],
      "writeProtocol": "append_first_with_idempotency",
      "readApis": [
        "receiptQuery",
        "paginatedTenantReceiptQuery",
        "reviewPolicyQuery",
        "reviewGateEvaluation"
      ]
    },
    "fabric": {
      "path": "services/fabric",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "resourceCatalog",
        "computeAllocations",
        "storageVolumes",
        "storageAttachments",
        "workspaceRuntimes",
        "jobs",
        "providerRequests"
      ],
      "cloudSdkOwner": true,
      "cloudSdks": [
        "tencentcloud-sdk-go",
        "kubernetes-client-go"
      ],
      "providerFactsBatchRead": {
        "endpoint": "POST /fabric/provider-facts/batch",
        "requestDto": {
          "items": ["accountId", "workspaceId", "resourceType", "resourceId"]
        },
        "responseDto": {
          "items": ["accountId", "workspaceId", "resourceType", "resourceId", "available", "facts", "errorCode"]
        },
        "batchSizeMax": 50,
        "readOnly": true,
        "computeAndStorageAuthority": "tencent_describe",
        "attachmentAndRuntimeAuthority": "fabric_and_kubernetes_live_readback",
        "independentTimeouts": true,
        "unavailableFallback": "none",
        "tencentMutationCount": 0
      },
      "gatewaySecretWrite": {
        "endpoint": "POST /fabric/gateway-secrets",
        "requestFields": ["accountId", "workspaceId", "workspaceApiKeyId", "fingerprint", "gatewayApiKey"],
        "newWriteScope": "workspace",
        "legacyReadCompatibility": "explicit_persisted_scope_or_ref_only"
      },
      "workspaceLaunchManualReviewProviderTruth": {
        "endpoint": "GET /fabric/monthly-provider-truth?computeAllocationId=<id>&storageVolumeId=<id>",
        "scope": "workspace.launch.v2_manual_review_recovery_only",
        "providerAction": "provider_truth",
        "providerAuthority": "existing_tencent_provisioner_describe_only",
        "localIdentityInputs": ["computeAllocationId", "storageVolumeId"],
        "outcomes": ["present", "absent", "unknown"],
        "exactVerificationFacts": ["provider_identity", "sku", "zone", "ownership", "chargeType=PREPAID", "renewFlag=NOTIFY_AND_MANUAL_RENEW", "deadline"],
        "unknownWhen": "either_local_identity_missing_or_any_exact_fact_unverifiable",
        "unknownPolicy": "remain_manual_review_never_absent_never_refund",
        "absentRequires": "both_local_identities_and_exact_provider_describe_absence",
        "forbiddenSideEffects": ["sync", "tag", "kubectl_apply", "delete", "label", "purchase", "renew", "destroy"]
      }
    }
  },
  "externalServices": {
    "gateway": {
      "product": "Sub2API",
      "origin": "configured_sub2api_base_url",
      "owns": [
        "customerIdentities",
        "customerPasswords",
        "spendableBalances",
        "apiKeys",
        "routePolicies",
        "modelPolicies",
        "usageEvents"
      ],
      "controlPlaneApi": [
        "read mapped user balance",
        "read mapped user API keys with bounded upstream pagination filters and sorting",
        "read mapped user available groups",
        "project configured public model endpoint",
        "read scoped request usage",
        "read scoped aggregate usage stats",
        "read mapped users by exact ID and batch user/key usage",
        "read mapped user balance history",
        "create and redeem adjustment",
        "mutate owned general keys including group quota IP expiry rate limits and resets with delegated user credentials"
      ],
      "customerProjection": "strict_allowlist_with_integer_usd_micros_and_no_local_usage_copy",
      "currentImplementation": "exact_id_current_page_users_batch_usage_bounded_key_counts_and_full_delegated_key_parity_code_complete_local_only"
    }
  },
  "browserBoundary": {
    "onlyCalls": "control_plane_product_apis",
    "publicEndpointDisplay": "copyable_text_only",
    "forbidden": ["sub2api_direct", "gflabtoken_link", "iframe", "html_scraping", "raw_admin_dto"]
  },
  "customerMutationBoundary": {
    "payment": false,
    "topUp": false,
    "keyCreate": true,
    "keyRevoke": true
  },
  "migration": {
    "compatibilityLayer": "forbidden",
    "allowedBridge": "none_fresh_database",
    "retireNodeApi": true,
    "retireNodeStore": true,
    "startupProtocol": {
      "lock": "database_wide_postgresql_advisory_lock",
      "journal": "opl_schema_migrations_service_version",
      "successRule": "record_after_success_only",
      "repeatStart": "skip_completed_versions"
    }
  },
  "forbiddenRuntimeMarkers": {
    "consoleUi": [
      "pg",
      "postgres",
      "DATABASE_URL",
      "tencentcloud",
      "kubernetes",
      "SecretId",
      "SecretKey"
    ],
    "controlPlane": [
      "tencentcloud",
      "kubernetes/client-go"
    ],
    "ledger": [
      "tencentcloud",
      "kubernetes/client-go",
      "workspace runtime deployment"
    ],
    "fabric": []
  },
  "secretPolicy": {
    "forbiddenEvidenceMarkers": [
      "token",
      "secret",
      "signedUrl",
      "presignedUrl",
      "objectKey",
      "SecretId",
      "SecretKey",
      "kubeconfig"
    ],
    "allowedEvidenceReferences": [
      "workspaceId",
      "organizationId",
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId",
      "redactedUrl",
      "providerRequestId",
      "operationId",
      "sub2apiUserId",
      "sub2apiRedeemCode"
    ]
  }
}
