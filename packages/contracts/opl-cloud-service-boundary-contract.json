{
  "schemaVersion": 1,
  "owner": "OPL Platform Architecture",
  "purpose": "Target ownership contract for Console UI, Control Plane, Ledger, Fabric, and the external Gateway boundary.",
  "state": "current",
  "machineBoundary": "Service ownership, persistence, cloud SDK ownership, external Gateway evidence handoff, migration, runtime marker, and evidence secret rules.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current service-boundary contract after all callers and deployments move to the new boundary."
  },
  "services": {
    "consoleUi": {
      "path": "apps/console-ui",
      "language": "typescript",
      "framework": "react",
      "persistence": "none",
      "calls": {
        "controlPlane": "http"
      }
    },
    "controlPlane": {
      "path": "services/control-plane",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "auth",
        "organizations",
        "memberships",
        "workspaces",
        "projectTaskSyncHeads",
        "executionRequests",
        "approvals",
        "supportTicketMappings",
        "operationRequests"
      ],
      "calls": {
        "ledger": "http",
        "fabric": "http"
      }
    },
    "ledger": {
      "path": "services/ledger",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "wallets",
        "holds",
        "manualTopups",
        "ledgerEntries",
        "walletTransactions",
        "evidenceReceipts",
        "artifactManifests",
        "reviewResults",
        "continuations",
        "auditEvents",
        "idempotencyKeys",
        "reconciliationReports"
      ],
      "writeProtocol": "append_first_with_idempotency"
    },
    "fabric": {
      "path": "services/fabric",
      "language": "go",
      "persistence": "optional_postgresql_for_async_operations",
      "owns": [
        "resourceCatalog",
        "computeAllocations",
        "storageVolumes",
        "storageAttachments",
        "workspaceRuntimes",
        "jobs",
        "providerRequests"
      ],
      "cloudSdkOwner": true,
      "cloudSdks": [
        "tencentcloud-sdk-go",
        "kubernetes-client-go"
      ]
    }
  },
  "externalServices": {
    "gateway": {
      "repository": "opl-gateway",
      "owns": [
        "gatewayKeys",
        "routePolicies",
        "modelPolicies",
        "usageEvents"
      ],
      "calls": {
        "ledger": "evidence_api"
      },
      "evidenceSink": "ledger"
    }
  },
  "migration": {
    "compatibilityLayer": "forbidden",
    "allowedBridge": "one_time_state_migration_only",
    "retireNodeApi": true,
    "retireNodeStore": true
  },
  "forbiddenRuntimeMarkers": {
    "consoleUi": [
      "pg",
      "postgres",
      "DATABASE_URL",
      "tencentcloud",
      "kubernetes",
      "SecretId",
      "SecretKey"
    ],
    "controlPlane": [
      "tencentcloud",
      "kubernetes/client-go",
      "ledger_entries INSERT",
      "manual_topups INSERT",
      "wallet_transactions INSERT"
    ],
    "ledger": [
      "tencentcloud",
      "kubernetes/client-go",
      "workspace runtime deployment"
    ],
    "fabric": [
      "manual_topups",
      "wallet_transactions",
      "ledger_entries"
    ]
  },
  "secretPolicy": {
    "forbiddenEvidenceMarkers": [
      "token",
      "secret",
      "signedUrl",
      "presignedUrl",
      "objectKey",
      "SecretId",
      "SecretKey",
      "kubeconfig"
    ],
    "allowedEvidenceReferences": [
      "workspaceId",
      "organizationId",
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId",
      "tokenVersion",
      "redactedUrl",
      "providerRequestId",
      "ledgerEntryId",
      "operationId"
    ]
  }
}
