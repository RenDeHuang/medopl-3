{
  "schemaVersion": 4,
  "owner": "OPL Platform Architecture",
  "purpose": "Current ownership contract for Console UI, Control Plane, Ledger, Fabric, and external Sub2API.",
  "state": "current",
  "machineBoundary": "Service ownership, persistence, cloud SDK ownership, Sub2API balance access, and evidence rules.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current service-boundary contract."
  },
  "services": {
    "consoleUi": {
      "path": "apps/console-ui",
      "language": "typescript",
      "framework": "react",
      "persistence": "none",
      "calls": {
        "controlPlane": "http"
      }
    },
    "controlPlane": {
      "path": "services/control-plane",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "auth",
        "organizations",
        "memberships",
        "workspaces",
        "monthlyEntitlements",
        "billingOperations",
        "projectTaskSyncHeads",
        "executionRequests",
        "approvals",
        "supportTicketMappings",
        "operationRequests"
      ],
      "calls": {
        "ledger": "http",
        "fabric": "http",
        "sub2api": "http"
      }
    },
    "ledger": {
      "path": "services/ledger",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "evidenceReceipts",
        "artifactManifests",
        "reviewResults",
        "reviewPolicies",
        "continuations",
        "auditEvents",
        "idempotencyKeys",
        "reconciliationReports"
      ],
      "writeProtocol": "append_first_with_idempotency",
      "readApis": [
        "receiptQuery",
        "reviewPolicyQuery",
        "reviewGateEvaluation"
      ]
    },
    "fabric": {
      "path": "services/fabric",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "resourceCatalog",
        "computeAllocations",
        "storageVolumes",
        "storageAttachments",
        "workspaceRuntimes",
        "jobs",
        "providerRequests"
      ],
      "cloudSdkOwner": true,
      "cloudSdks": [
        "tencentcloud-sdk-go",
        "kubernetes-client-go"
      ]
    }
  },
  "externalServices": {
    "gateway": {
      "product": "Sub2API",
      "origin": "https://gflabtoken.cn",
      "owns": [
        "spendableBalances",
        "apiKeys",
        "routePolicies",
        "modelPolicies",
        "usageEvents"
      ],
      "controlPlaneApi": [
        "read balance",
        "create and redeem adjustment"
      ]
    }
  },
  "migration": {
    "compatibilityLayer": "forbidden",
    "allowedBridge": "none_fresh_database",
    "retireNodeApi": true,
    "retireNodeStore": true,
    "startupProtocol": {
      "lock": "database_wide_postgresql_advisory_lock",
      "journal": "opl_schema_migrations_service_version",
      "successRule": "record_after_success_only",
      "repeatStart": "skip_completed_versions"
    }
  },
  "forbiddenRuntimeMarkers": {
    "consoleUi": [
      "pg",
      "postgres",
      "DATABASE_URL",
      "tencentcloud",
      "kubernetes",
      "SecretId",
      "SecretKey"
    ],
    "controlPlane": [
      "tencentcloud",
      "kubernetes/client-go"
    ],
    "ledger": [
      "tencentcloud",
      "kubernetes/client-go",
      "workspace runtime deployment"
    ],
    "fabric": []
  },
  "secretPolicy": {
    "forbiddenEvidenceMarkers": [
      "token",
      "secret",
      "signedUrl",
      "presignedUrl",
      "objectKey",
      "SecretId",
      "SecretKey",
      "kubeconfig"
    ],
    "allowedEvidenceReferences": [
      "workspaceId",
      "organizationId",
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId",
      "tokenVersion",
      "redactedUrl",
      "providerRequestId",
      "operationId",
      "sub2apiUserId",
      "sub2apiRedeemCode"
    ]
  }
}
