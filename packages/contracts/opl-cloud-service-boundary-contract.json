{
  "schemaVersion": 6,
  "owner": "OPL Platform Architecture",
  "purpose": "Current ownership contract for Console UI, Control Plane, Ledger, Fabric, and external Sub2API.",
  "state": "current",
  "machineBoundary": "Service ownership, persistence, cloud SDK ownership, live customer fact projection, Sub2API balance access, and evidence rules.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current service-boundary contract."
  },
  "services": {
    "consoleUi": {
      "path": "apps/console-ui",
      "language": "typescript",
      "framework": "vue",
      "persistence": "none",
      "calls": {
        "controlPlane": "http"
      }
    },
    "controlPlane": {
      "path": "services/control-plane",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "sessions",
        "announcements",
        "announcementReads",
        "accountMappings",
        "internalOneToOneIdentityCompatibilityRecords",
        "workspaces",
        "monthlyEntitlements",
        "billingOperations",
        "latestReconciliationGuard",
        "projectTaskSyncHeads",
        "executionRequests",
        "approvals",
        "supportTicketMappings",
        "operationRequests"
      ],
      "calls": {
        "ledger": "http",
        "fabric": "http",
        "sub2api": "http"
      },
      "ephemeralOnly": ["sessionDelegatedGatewayCredential"],
      "forbiddenPersistence": ["gatewayCredentials", "apiKeys", "apiUsage", "walletBalances", "runtimeFileMetadata"]
    },
    "ledger": {
      "path": "services/ledger",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "evidenceReceipts",
        "artifactManifests",
        "reviewResults",
        "reviewPolicies",
        "continuations",
        "auditEvents",
        "idempotencyKeys",
        "reconciliationReports"
      ],
      "writeProtocol": "append_first_with_idempotency",
      "readApis": [
        "receiptQuery",
        "paginatedTenantReceiptQuery",
        "reviewPolicyQuery",
        "reviewGateEvaluation"
      ]
    },
    "fabric": {
      "path": "services/fabric",
      "language": "go",
      "persistence": "postgresql",
      "owns": [
        "resourceCatalog",
        "computeAllocations",
        "storageVolumes",
        "storageAttachments",
        "workspaceRuntimes",
        "jobs",
        "providerRequests"
      ],
      "cloudSdkOwner": true,
      "cloudSdks": [
        "tencentcloud-sdk-go",
        "kubernetes-client-go"
      ]
    }
  },
  "externalServices": {
    "gateway": {
      "product": "Sub2API",
      "origin": "configured_sub2api_base_url",
      "owns": [
        "customerIdentities",
        "customerPasswords",
        "spendableBalances",
        "apiKeys",
        "routePolicies",
        "modelPolicies",
        "usageEvents"
      ],
      "controlPlaneApi": [
        "read mapped user balance",
        "read mapped user API keys",
        "read scoped request usage",
        "read scoped aggregate usage stats",
        "read paginated users and batch user/key usage",
        "read mapped user balance history",
        "create and redeem adjustment",
        "mutate owned general keys with delegated user credentials"
      ],
      "customerProjection": "strict_allowlist_with_integer_usd_micros_and_no_local_usage_copy"
    }
  },
  "browserBoundary": {
    "onlyCalls": "control_plane_product_apis",
    "gatewayPublicEndpoint": {
      "configEnv": "OPL_GATEWAY_PUBLIC_BASE_URL",
      "productionScheme": "https",
      "forbiddenFallbacks": ["OPL_SUB2API_BASE_URL", "gflabtoken.cn"]
    },
    "forbidden": ["sub2api_direct", "gflabtoken_link", "iframe", "html_scraping", "raw_admin_dto"]
  },
  "customerMutationBoundary": {
    "payment": false,
    "topUp": false,
    "keyCreate": true,
    "keyRevoke": true
  },
  "migration": {
    "compatibilityLayer": "forbidden",
    "allowedBridge": "none_fresh_database",
    "retireNodeApi": true,
    "retireNodeStore": true,
    "startupProtocol": {
      "lock": "database_wide_postgresql_advisory_lock",
      "journal": "opl_schema_migrations_service_version",
      "successRule": "record_after_success_only",
      "repeatStart": "skip_completed_versions"
    }
  },
  "forbiddenRuntimeMarkers": {
    "consoleUi": [
      "pg",
      "postgres",
      "DATABASE_URL",
      "tencentcloud",
      "kubernetes",
      "SecretId",
      "SecretKey"
    ],
    "controlPlane": [
      "tencentcloud",
      "kubernetes/client-go"
    ],
    "ledger": [
      "tencentcloud",
      "kubernetes/client-go",
      "workspace runtime deployment"
    ],
    "fabric": []
  },
  "secretPolicy": {
    "forbiddenEvidenceMarkers": [
      "token",
      "secret",
      "signedUrl",
      "presignedUrl",
      "objectKey",
      "SecretId",
      "SecretKey",
      "kubeconfig"
    ],
    "allowedEvidenceReferences": [
      "workspaceId",
      "organizationId",
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId",
      "redactedUrl",
      "providerRequestId",
      "operationId",
      "sub2apiUserId",
      "sub2apiRedeemCode"
    ]
  }
}
