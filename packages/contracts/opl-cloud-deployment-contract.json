  "imageReleaseWorkflow": {
    "file": ".github/workflows/release-opl-cloud-image.yml",
    "job": "build-push",
    "runner": [
      "ubuntu-latest"
    ],
    "inputs": [
      "ref",
      "image_tag",
      "publish_cloud_image",
      "publish_workspace_image",
      "workspace_app_main_sha",
      "workspace_shell_main_sha",
      "workspace_framework_main_sha"
    ],
    "outputs": ["cloud_image", "workspace_image"],
    "skippedOutput": "empty",
    "cloudCandidate": {
      "input": "ref",
      "repositoryAuthority": "github.repository",
      "requirements": ["40_character_git_sha", "checked_out_head_exact_match", "merged_into_workflow_repository_main"],
      "mainReadback": "refs/remotes/release-source/main"
    },
    "env": {
      "OPL_CLOUD_IMAGE_REPOSITORY": "uswccr.ccs.tencentyun.com/oplcloud/opl-cloud",
      "OPL_CLOUD_SOURCE_REPOSITORY": "${{ github.repository }}",
      "OPL_WORKSPACE_IMAGE_REPOSITORY": "uswccr.ccs.tencentyun.com/oplcloud/one-person-lab-app"
    },
    "requiredCommandsByStep": {
      "Verify Cloud source": [
        "^[0-9a-fA-F]{40}$",
        "git rev-parse HEAD",
        "git fetch --no-tags \"https://github.com/${OPL_CLOUD_SOURCE_REPOSITORY}.git\" main:refs/remotes/release-source/main",
        "git rev-parse refs/remotes/release-source/main",
        "git merge-base --is-ancestor \"$cloud_head_sha\" \"$cloud_main_sha\""
      ],
      "Image metadata": [
        "^[0-9a-fA-F]{40}$",
        "REQUESTED_WORKSPACE_APP_SHA",
        "REQUESTED_WORKSPACE_SHELL_SHA",
        "REQUESTED_WORKSPACE_FRAMEWORK_SHA",
        "workspace_image_tag=\"${workspace_app_sha:0:12}-${workspace_shell_sha:0:12}-${workspace_framework_sha:0:12}\""
      ],
      "Set up Node": [
        "actions/setup-node@v4",
        "node-version"
      ],
      "Prepare Workspace App source": [
        "git clone --filter=blob:none --single-branch --branch main",
        "https://github.com/gaofeng21cn/one-person-lab-app.git",
        "https://github.com/gaofeng21cn/opl-aion-shell.git",
        "https://github.com/gaofeng21cn/one-person-lab.git",
        "merge-base --is-ancestor",
        "checkout --detach",
        "npm run ensure:shell",
        "rev-parse HEAD",
        "grep -Fxq '.git'"
      ],
      "Build and push images": [
        "docker login uswccr.ccs.tencentyun.com --username \"$TCR_ID\" --password-stdin",
        "docker buildx build --push -f Dockerfile -t \"$OPL_CLOUD_IMAGE_REF\" \"$OPL_CLOUD_IMAGE_CONTEXT\"",
        "-f \"$OPL_WORKSPACE_SOURCE_ROOT/shells/aionui/Dockerfile\"",
        "--build-arg OPL_FRAMEWORK_REF=\"$OPL_WORKSPACE_FRAMEWORK_SHA\"",
        "\"$OPL_WORKSPACE_SOURCE_ROOT/shells/aionui\"",
        "docker buildx imagetools inspect \"$OPL_WORKSPACE_IMAGE_REF\""
      ]
    },
    "forbiddenRunTokens": [
      "docker login ghcr.io",
      "imagetools create",
      "git ls-remote",
      "org.opencontainers.image.revision",
      ":latest",
      "@latest"
    ]
