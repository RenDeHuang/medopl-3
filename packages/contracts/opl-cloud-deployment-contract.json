{
  "schemaVersion": 1,
  "owner": "OPL Fabric",
  "purpose": "Deployment workflow, production image, TKE handoff, and paid production verification contract.",
  "state": "current",
  "machineBoundary": "GitHub workflow structure, runner isolation, deploy-time env sources, secret handling, image release, and one paid verifier.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "runner": [
    "self-hosted",
    "tencent-cloud",
    "opl-cloud",
    "tke-vpc"
  ],
  "environment": "production",
  "deployWorkflow": {
    "file": ".github/workflows/deploy-tke-production.yml",
    "job": "deploy",
    "inputs": [
      "cloud_image",
      "workspace_image"
    ],
    "requiredEnv": [
      "OPL_RUNTIME_PROVIDER",
      "OPL_K8S_NAMESPACE",
      "OPL_PUBLIC_URL",
      "OPL_CONSOLE_DOMAIN",
      "OPL_WORKSPACE_DOMAIN",
      "OPL_CLOUD_IMAGE",
      "OPL_WORKSPACE_IMAGE",
      "OPL_IMAGE_PULL_SECRET_NAME",
      "OPL_WORKSPACE_STORAGE_CLASS",
      "OPL_TENCENT_PROVISIONER_BIN",
      "OPL_WORKSPACE_VOLUME_SNAPSHOT_CLASS",
      "OPL_CONSOLE_TLS_SECRET_NAME",
      "OPL_WORKSPACE_TLS_SECRET_NAME",
      "OPL_INGRESS_CLASS",
      "OPL_WORKSPACE_WEBUI_PORT",
      "OPL_WORKSPACE_DATA_DIR",
      "OPL_WORKSPACE_PROJECTS_DIR",
      "OPL_MONTHLY_BILLING_WORKER_ENABLED",
      "OPL_MONTHLY_BILLING_INTERVAL_MS",
      "OPL_BASIC_COMPUTE_INSTANCE_TYPE",
      "OPL_PRO_COMPUTE_INSTANCE_TYPE",
      "OPL_CODEX_MODEL",
      "OPL_CODEX_REASONING_EFFORT",
      "OPL_CODEX_BASE_URL",
      "OPL_SUB2API_BASE_URL",
      "OPL_SUB2API_SUPPORTED_VERSIONS",
      "OPL_SUB2API_REQUEST_TIMEOUT_MS",
      "OPL_SUB2API_ADMIN_EMAIL",
      "OPL_SUB2API_ADMIN_PASSWORD",
      "TENCENTCLOUD_SECRET_ID",
      "TENCENTCLOUD_SECRET_KEY",
      "TENCENTCLOUD_REGION",
      "TENCENT_DEPLOY_CLUSTER_ID",
      "TENCENT_CVM_SUBNET_ID",
      "TENCENT_CVM_SECURITY_GROUP_IDS",
      "TENCENT_CVM_SYSTEM_DISK_TYPE",
      "TENCENT_CVM_SYSTEM_DISK_SIZE_GB",
      "RUN_TENCENT_CREATE_RELEASE_EXECUTION",
      "TENCENT_TCR_REGISTRY",
      "TENCENT_TCR_NAMESPACE",
      "TENCENT_TCR_REGION",
      "TENCENT_DEPLOY_KUBECONFIG_REF",
      "DATABASE_URL",
      "OPL_INTERNAL_SERVICE_TOKEN",
      "OPL_CONSOLE_USERS_JSON",
      "TCR_USERNAME",
      "TCR_PASSWORD"
    ],
    "secretEnv": [
      "DATABASE_URL",
      "OPL_INTERNAL_SERVICE_TOKEN",
      "OPL_CONSOLE_USERS_JSON",
      "OPL_OPERATOR_SUMMARY_TOKEN",
      "OPL_CODEX_API_KEY",
      "OPL_SUB2API_ADMIN_EMAIL",
      "OPL_SUB2API_ADMIN_PASSWORD",
      "TENCENTCLOUD_SECRET_ID",
      "TENCENTCLOUD_SECRET_KEY",
      "TCR_USERNAME",
      "TCR_PASSWORD",
      "TENCENT_DEPLOY_KUBECONFIG_B64",
      "TENCENT_DEPLOY_KUBECONFIG"
    ],
    "steps": [
      "Checkout",
      "Set up Node",
      "Prepare kubeconfig",
      "Check deployment inputs",
      "Verify TKE access",
      "Check TLS certificate inputs",
      "Install Kubernetes secrets",
      "Install and verify TLS secret",
      "Render and apply manifest",
      "Show ingress target",
      "Remove deployment secrets"
    ],
    "orderedSteps": [
      [
        "Check TLS certificate inputs",
        "Install Kubernetes secrets"
      ],
      [
        "Render and apply manifest",
        "Show ingress target"
      ],
      [
        "Show ingress target",
        "Remove deployment secrets"
      ]
    ],
    "requiredCommandsByStep": {
      "Set up Node": [
        "node-version",
        "22"
      ],
      "Prepare kubeconfig": [
        "TENCENT_DEPLOY_KUBECONFIG_PATH",
        "TENCENT_DEPLOY_KUBECONFIG_B64",
        "TENCENT_DEPLOY_KUBECONFIG"
      ],
      "Install Kubernetes secrets": [
        "--from-file=DATABASE_URL=\"$secret_dir/database-url\"",
        "--from-file=OPL_INTERNAL_SERVICE_TOKEN=\"$secret_dir/internal-service-token\"",
        "--from-file=OPL_CONSOLE_USERS_JSON=\"$secret_dir/auth-users-json\"",
        "--from-file=OPL_CODEX_API_KEY=\"$secret_dir/codex-api-key\"",
        "--from-file=OPL_SUB2API_ADMIN_EMAIL=\"$secret_dir/sub2api-admin-email\"",
        "--from-file=OPL_SUB2API_ADMIN_PASSWORD=\"$secret_dir/sub2api-admin-password\"",
        "--from-file=TENCENTCLOUD_SECRET_ID=\"$secret_dir/tencentcloud-secret-id\"",
        "--from-file=TENCENTCLOUD_SECRET_KEY=\"$secret_dir/tencentcloud-secret-key\"",
        "--from-file=.dockerconfigjson=\"$docker_config\"",
        "--from-file=kubeconfig=\"$KUBECONFIG\""
      ],
      "Install and verify TLS secret": [
        "install_qcloud_cert_secret",
        "verify_qcloud_cert_secret",
        "qcloud_cert_id"
      ],
      "Render and apply manifest": [
        "node tools/render-tke-manifest.ts --manifest deploy/tke/opl-cloud.k8s.json --out \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.ingress-bootstrap.json\"",
        "node tools/render-tke-manifest.ts --manifest deploy/tke/opl-cloud.k8s.json --skip-shared-ingress --out \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.rendered.json\"",
        "kubectl --kubeconfig \"$KUBECONFIG\" apply -f \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.rendered.json\"",
        "opl-cloud-control-plane opl-cloud-ledger opl-cloud-fabric",
        "rollout restart \"deployment/$deployment\"",
        "rollout status \"deployment/$deployment\""
      ],
      "Remove deployment secrets": [
        "always()",
        "find \"$secret_dir\" -mindepth 1 -delete",
        "rmdir \"$secret_dir\""
      ]
    },
    "forbiddenRunTokens": [
      "--from-literal=DATABASE_URL",
      "--from-literal=OPL_INTERNAL_SERVICE_TOKEN",
      "--from-literal=OPL_CONSOLE_USERS_JSON",
      "--from-literal=OPL_OPERATOR_SUMMARY_TOKEN",
      "--docker-password"
    ]
  },
  "productionVerificationWorkflow": {
    "file": ".github/workflows/verify-production-chain.yml",
    "job": "verify",
    "runner": [
      "ubuntu-latest"
    ],
    "inputs": [
      "run_id",
      "account_id",
      "url_attempts",
      "retry_delay_ms",
      "paid_confirmation"
    ],
    "requiredEnv": [
      "OPL_CONSOLE_ORIGIN",
      "OPL_VERIFY_AUTH_USERS_JSON",
      "OPL_VERIFY_PAID_CONFIRMATION",
      "OPL_VERIFY_ACCOUNT_ID",
      "OPL_VERIFY_PACKAGE_ID",
      "OPL_VERIFY_URL_ATTEMPTS",
      "OPL_VERIFY_RETRY_DELAY_MS",
      "OPL_VERIFY_RUN_ID",
      "OPL_VERIFY_SCREENSHOT_DIR",
      "OPL_VERIFY_MANIFEST_PATH",
      "OPL_VERIFY_MODEL_ACCESS_KEY"
    ],
    "secretEnv": [
      "OPL_VERIFY_AUTH_USERS_JSON",
      "OPL_VERIFY_MODEL_ACCESS_KEY"
    ],
    "steps": [
      "Checkout",
      "Set up Node",
      "Install dependencies",
      "Install browser",
      "Verify production monthly billing chain",
      "Upload browser E2E screenshots and manifest"
    ],
    "requiredCommandsByStep": {
      "Set up Node": [
        "node-version",
        "22"
      ],
      "Install dependencies": [
        "npm ci"
      ],
      "Install browser": [
        "playwright install --with-deps chromium"
      ],
      "Verify production monthly billing chain": [
        "node tools/production-verifier.ts --browser-e2e",
        "workspace_id=",
        "workspace_url="
      ]
    },
    "forbiddenRunTokens": []
  },
  "imageReleaseWorkflow": {
    "file": ".github/workflows/release-opl-cloud-image.yml",
    "job": "build-push",
    "runner": [
      "ubuntu-latest"
    ],
    "inputs": [
      "ref",
      "image_tag",
      "publish_cloud_image",
      "mirror_workspace_image",
      "workspace_source_image",
      "workspace_image_tag"
    ],
    "env": {
      "OPL_CLOUD_IMAGE_REPOSITORY": "uswccr.ccs.tencentyun.com/oplcloud/opl-cloud",
      "OPL_WORKSPACE_IMAGE_REPOSITORY": "uswccr.ccs.tencentyun.com/oplcloud/one-person-lab-app"
    },
    "requiredCommandsByStep": {
      "Build and push images": [
        "docker login uswccr.ccs.tencentyun.com --username \"$TCR_ID\" --password-stdin",
        "docker login ghcr.io --username \"$GHCR_USERNAME\" --password-stdin",
        "docker buildx build --push -f Dockerfile -t \"$OPL_CLOUD_IMAGE_REF\" \"$OPL_CLOUD_IMAGE_CONTEXT\"",
        "docker buildx imagetools create -t \"$OPL_WORKSPACE_IMAGE_REF\" \"$WORKSPACE_SOURCE_IMAGE\""
      ]
    }
  },
  "controlPlaneImage": {
    "file": "Dockerfile",
    "baseImage": "node:22-bookworm-slim",
    "requiredInstructions": [
      "FROM golang:1.22-bookworm AS provisioner-build",
      "go build -o /out/opl-tencent-provisioner ./cmd/opl-tencent-provisioner",
      "go build -o /out/opl-control-plane ./cmd/control-plane",
      "npm ci --no-audit --no-fund --fetch-retries=5 --fetch-retry-mintimeout=20000 --fetch-retry-maxtimeout=120000",
      "npm ci --omit=dev --no-audit --no-fund --fetch-retries=5 --fetch-retry-mintimeout=20000 --fetch-retry-maxtimeout=120000",
      "npm run build",
      "kubectl",
      "COPY --from=provisioner-build /out/opl-tencent-provisioner /usr/local/bin/opl-tencent-provisioner",
      "COPY --from=control-plane-build /out/opl-control-plane /usr/local/bin/opl-control-plane",
      "COPY packages ./packages",
      "ENV CONTROL_PLANE_ADDR=:8787",
      "EXPOSE 8787",
      "CMD [\"/usr/local/bin/opl-control-plane\"]"
    ],
    "dockerignore": [
      "node_modules",
      "dist",
      ".runtime",
      ".git",
      ".env",
      ".env.*"
    ]
  }
}
