    "steps": [
      "Checkout",
      "Set up Node",
      "Prepare rollback kubeconfig",
      "Download rollback image set",
      "Restore previous Cloud and App images",
      "Remove rollback kubeconfig"
    ],
    "requiredCommandsByStep": {
      "Set up Node": [
        "node-version",
        "22"
      ],
      "Prepare rollback kubeconfig": [
        "TENCENT_DEPLOY_KUBECONFIG_PATH",
        "TENCENT_DEPLOY_KUBECONFIG_B64",
        "TENCENT_DEPLOY_KUBECONFIG"
      ],
      "Download rollback image set": [
        "actions/download-artifact@v4",
        "production-rollback-images"
      ],
      "Restore previous Cloud and App images": [
        "source tools/tke-image-rollout.sh",
        "restore_previous_images",
        "restore_previous_bootstrap_images",
        "opl-cloud-config.json",
        "previous Cloud images and ConfigMap"
      ],
      "Remove rollback kubeconfig": [
        "always()",
        "find \"$secret_dir\" -mindepth 1 -delete",
        "rmdir \"$secret_dir\""
      ]
    },
    "forbiddenRunTokens": [
      "set +e"
    ]
  },
  "imageReleaseWorkflow": {
    "file": ".github/workflows/release-opl-cloud-image.yml",
    "job": "build-push",
    "runner": [
      "ubuntu-latest"
    ],
    "inputs": [
      "ref",
      "image_tag",
      "publish_cloud_image",
      "publish_workspace_image",
      "workspace_app_main_sha",
      "workspace_shell_main_sha",
      "workspace_framework_main_sha"
    ],
    "outputs": ["cloud_image", "workspace_image"],
    "skippedOutput": "empty",
    "workspaceSourceInputs": {
      "required": false,
      "requiredWhen": "publish_workspace_image=true",
      "cloudOnlyBehavior": "not_validated_not_cloned_not_built"
    },
    "cloudCandidate": {
      "input": "ref",
      "repositoryAuthority": "github.repository",
      "requirements": ["40_character_git_sha", "checked_out_head_exact_match", "merged_into_workflow_repository_main"],
      "mainReadback": "refs/remotes/release-source/main"
    },
    "env": {
      "OPL_CLOUD_IMAGE_REPOSITORY": "uswccr.ccs.tencentyun.com/oplcloud/opl-cloud",
      "OPL_CLOUD_SOURCE_REPOSITORY": "${{ github.repository }}",
      "OPL_WORKSPACE_IMAGE_REPOSITORY": "uswccr.ccs.tencentyun.com/oplcloud/one-person-lab-app"
    },
    "requiredCommandsByStep": {
      "Verify Cloud source": [
        "^[0-9a-fA-F]{40}$",
        "git rev-parse HEAD",
        "git fetch --no-tags \"https://github.com/${OPL_CLOUD_SOURCE_REPOSITORY}.git\" main:refs/remotes/release-source/main",
        "git rev-parse refs/remotes/release-source/main",
        "git merge-base --is-ancestor \"$cloud_head_sha\" \"$cloud_main_sha\""
      ],
      "Image metadata": [
        "^[0-9a-fA-F]{40}$",
        "REQUESTED_WORKSPACE_APP_SHA",
        "REQUESTED_WORKSPACE_SHELL_SHA",
        "REQUESTED_WORKSPACE_FRAMEWORK_SHA",
        "workspace_image_tag=\"${workspace_app_sha:0:12}-${workspace_shell_sha:0:12}-${workspace_framework_sha:0:12}\""
      ],
      "Set up Node": [
        "actions/setup-node@v4",
        "node-version"
      ],
      "Prepare Workspace App source": [
        "git clone --filter=blob:none --single-branch --branch main",
        "https://github.com/gaofeng21cn/one-person-lab-app.git",
        "https://github.com/gaofeng21cn/opl-aion-shell.git",
        "https://github.com/gaofeng21cn/one-person-lab.git",
        "merge-base --is-ancestor",
        "checkout --detach",
        "npm run ensure:shell",
        "rev-parse HEAD",
        "grep -Fxq '.git'"
      ],
      "Build and push images": [
        "docker login uswccr.ccs.tencentyun.com --username \"$TCR_ID\" --password-stdin",
        "docker buildx build --push -f Dockerfile -t \"$OPL_CLOUD_IMAGE_REF\" \"$OPL_CLOUD_IMAGE_CONTEXT\"",
        "-f \"$OPL_WORKSPACE_SOURCE_ROOT/shells/aionui/Dockerfile\"",
        "--build-arg OPL_FRAMEWORK_REF=\"$OPL_WORKSPACE_FRAMEWORK_SHA\"",
        "\"$OPL_WORKSPACE_SOURCE_ROOT/shells/aionui\"",
        "docker buildx imagetools inspect \"$OPL_WORKSPACE_IMAGE_REF\""
      ]
    },
    "forbiddenRunTokens": [
      "docker login ghcr.io",
      "imagetools create",
      "git ls-remote",
      "org.opencontainers.image.revision",
      ":latest",
      "@latest"
    ]
  },
  "workspaceImage": {
    "appRepository": "https://github.com/gaofeng21cn/one-person-lab-app.git",
    "activeShellRepository": "https://github.com/gaofeng21cn/opl-aion-shell.git",
    "frameworkRepository": "https://github.com/gaofeng21cn/one-person-lab.git",
    "candidateAppMainSha": "6b334ef7f239eb01c40578159e6df9ed2e7f97dc",
    "candidateActiveShellMainSha": "dbd9d68115604673df85033d7a0ab323d65a79a2",
    "candidateFrameworkMainSha": "51d16f0e93aebf3fd5ccf96082490395fcbb8711",
    "candidateRequirements": ["40_character_git_sha", "merged_into_repository_main"],
    "targetRepository": "uswccr.ccs.tencentyun.com/oplcloud/one-person-lab-app",
    "candidateTagFormat": "<app-sha-12>-<active-shell-sha-12>-<framework-sha-12>",
    "immutableTcrDigest": null,
    "immutableTcrDigestStatus": "pending_publication_readback",
    "readyPodImageId": null,
    "readyPodImageIdStatus": "pending_deployment_readback",
    "productionReference": "repository@sha256",
    "mutableTagsForbidden": ["latest", "stable"]
  },
  "controlPlaneImage": {
    "file": "Dockerfile",
    "baseImage": "node:22-bookworm-slim",
    "requiredInstructions": [
      "FROM golang:1.22-bookworm AS provisioner-build",
      "go build -o /out/opl-tencent-provisioner ./cmd/opl-tencent-provisioner",
      "go build -o /out/opl-control-plane ./cmd/control-plane",
      "npm ci --no-audit --no-fund --fetch-retries=5 --fetch-retry-mintimeout=20000 --fetch-retry-maxtimeout=120000",
      "npm ci --omit=dev --no-audit --no-fund --fetch-retries=5 --fetch-retry-mintimeout=20000 --fetch-retry-maxtimeout=120000",
      "npm run build",
      "kubectl",
      "COPY --from=provisioner-build /out/opl-tencent-provisioner /usr/local/bin/opl-tencent-provisioner",
      "COPY --from=control-plane-build /out/opl-control-plane /usr/local/bin/opl-control-plane",
      "COPY packages ./packages",
      "ENV CONTROL_PLANE_ADDR=:8787",
      "EXPOSE 8787",
      "CMD [\"/usr/local/bin/opl-control-plane\"]"
    ],
    "dockerignore": [
      "node_modules",
      "dist",
      ".runtime",
      ".git",
      ".env",
      ".env.*"
    ]
  }
}
