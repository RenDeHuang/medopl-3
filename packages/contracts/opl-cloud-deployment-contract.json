        "source tools/tke-image-rollout.sh",
        "list_workspace_images"
      ],
      "Upload rollback image set": [
        "actions/upload-artifact@v4",
        "production-rollback-images",
        "previous-images"
      ],
      "Render and apply manifest": [
        "node tools/render-tke-manifest.ts --manifest deploy/tke/opl-cloud.k8s.json --out \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.ingress-bootstrap.json\"",
        "node tools/render-tke-manifest.ts --manifest deploy/tke/opl-cloud.k8s.json --skip-shared-ingress --out \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.rendered.json\"",
        "kubectl --kubeconfig \"$KUBECONFIG\" apply -f \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.rendered.json\"",
        "source tools/tke-image-rollout.sh",
        "apply_candidate_images",
        "restore_previous_images"
      ],
      "Remove deployment secrets": [
        "always()",
        "find \"$secret_dir\" -mindepth 1 -delete",
        "rmdir \"$secret_dir\""
      ]
    },
