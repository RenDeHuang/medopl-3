        "node-version",
        "22"
      ],
      "Prepare kubeconfig": [
        "TENCENT_DEPLOY_KUBECONFIG_PATH",
        "TENCENT_DEPLOY_KUBECONFIG_B64",
        "TENCENT_DEPLOY_KUBECONFIG"
      ],
      "Check deployment inputs": [
        "OPL_CLOUD_IMAGE",
        "OPL_WORKSPACE_IMAGE",
        "get configmap opl-cloud-config",
        "current_workspace_image",
        "requested_workspace_image",
        "must match the current production Workspace image",
        "sha256"
      ],
      "Install Kubernetes secrets": [
        "--from-file=DATABASE_URL=\"$secret_dir/database-url\"",
        "--from-file=OPL_INTERNAL_SERVICE_TOKEN=\"$secret_dir/internal-service-token\"",
        "--from-file=OPL_SUB2API_ADMIN_EMAIL=\"$secret_dir/sub2api-admin-email\"",
        "--from-file=OPL_SUB2API_ADMIN_PASSWORD=\"$secret_dir/sub2api-admin-password\"",
        "--from-file=TENCENTCLOUD_SECRET_ID=\"$secret_dir/tencentcloud-secret-id\"",
        "--from-file=TENCENTCLOUD_SECRET_KEY=\"$secret_dir/tencentcloud-secret-key\"",
        "--from-file=.dockerconfigjson=\"$docker_config\"",
        "--from-file=kubeconfig=\"$KUBECONFIG\""
      ],
      "Install and verify TLS secret": [
        "install_qcloud_cert_secret",
        "verify_qcloud_cert_secret",
        "qcloud_cert_id"
      ],
      "Capture rollback image set": [
        "opl-cloud-control-plane:control-plane",
        "opl-cloud-ledger:ledger",
        "opl-cloud-fabric:fabric",
        "get configmap opl-cloud-config",
        "-o json",
        "opl-cloud-config.json"
      ],
      "Upload rollback image set": [
        "actions/upload-artifact@v4",
        "production-rollback-images",
        "previous-images"
      ],
      "Render and apply manifest": [
        "node tools/render-tke-manifest.ts --manifest deploy/tke/opl-cloud.k8s.json --out \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.ingress-bootstrap.json\"",
        "node tools/render-tke-manifest.ts --manifest deploy/tke/opl-cloud.k8s.json --skip-shared-ingress --out \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.rendered.json\"",
        "kubectl --kubeconfig \"$KUBECONFIG\" apply -f \"$OPL_DEPLOY_SECRET_DIR/opl-cloud.rendered.json\"",
        "source tools/tke-image-rollout.sh",
        "apply_candidate_images",
        "apply_bootstrap_images",
        "restore_previous_images",
        "restore_previous_bootstrap_images"
      ],
      "Remove deployment secrets": [
        "always()",
        "find \"$secret_dir\" -mindepth 1 -delete",
        "rmdir \"$secret_dir\""
      ]
    },
    "workspaceImageInputPolicy": {
      "required": false,
      "ordinaryAuthority": "opl-cloud-config.data.OPL_WORKSPACE_IMAGE",
      "providedValue": "must_equal_current_production_digest",
      "bootstrapWithoutConfigMap": "explicit_digest_required",
