{
  "schemaVersion": 3,
  "owner": "OPL Platform Architecture",
  "purpose": "Canonical cross-surface execution identity, state, write, ownership, and error contract.",
  "state": "current",
  "machineBoundary": "Canonical Project-to-Continuation identities, execution states, mutation envelope, logical service operations, error semantics, and one cross-repository example.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current shared execution contract after App, Gateway, Control Plane, Fabric, and Ledger callers move together."
  },
  "repositoryBoundaries": [
    "one-person-lab",
    "one-person-lab-app",
    "opl-console",
    "opl-fabric",
    "opl-ledger",
    "opl-gateway"
  ],
  "canonicalObjects": [
    {
      "kind": "Project",
      "service": "controlPlane",
      "ownershipKey": "projectTaskSyncHeads",
      "idField": "projectId",
      "idPrefix": "project-"
    },
    {
      "kind": "Task",
      "service": "controlPlane",
      "ownershipKey": "projectTaskSyncHeads",
      "idField": "taskId",
      "idPrefix": "task-"
    },
    {
      "kind": "ExecutionRequest",
      "service": "controlPlane",
      "ownershipKey": "executionRequests",
      "idField": "requestId",
      "idPrefix": "request-"
    },
    {
      "kind": "Approval",
      "service": "controlPlane",
      "ownershipKey": "approvals",
      "idField": "approvalId",
      "idPrefix": "approval-"
    },
    {
      "kind": "Job",
      "service": "fabric",
      "ownershipKey": "jobs",
      "idField": "jobId",
      "idPrefix": "job-"
    },
    {
      "kind": "Artifact",
      "service": "ledger",
      "ownershipKey": "artifactManifests",
      "idField": "artifactId",
      "idPrefix": "artifact-"
    },
    {
      "kind": "Review",
      "service": "ledger",
      "ownershipKey": "reviewResults",
      "idField": "reviewId",
      "idPrefix": "review-"
    },
    {
      "kind": "Receipt",
      "service": "ledger",
      "ownershipKey": "evidenceReceipts",
      "idField": "receiptId",
      "idPrefix": "receipt-"
    },
    {
      "kind": "Continuation",
      "service": "ledger",
      "ownershipKey": "continuations",
      "idField": "continuationId",
      "idPrefix": "continuation-"
    }
  ],
  "identity": {
    "canonicalIdFields": [
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId"
    ],
    "rules": [
      "Canonical ids are opaque globally unique strings created by the owning service.",
      "Canonical projectId and taskId do not change when execution moves between local App and cloud Workspace.",
      "Provider ids, Kubernetes names, object keys, database row ids, and local paths are references, not business identity.",
      "A job retry keeps jobId, increments attempt, and records a new operation with a new idempotencyKey."
    ],
    "temporaryLocalIds": {
      "allowedKinds": [
        "Project",
        "Task"
      ],
      "idPrefix": "local-",
      "promotion": "Create one canonical id transactionally and retain the temporary id only as a lookup alias.",
      "duplicateCloudIdentity": "forbidden"
    },
    "providerReferenceFields": [
      "providerResourceId",
      "providerRequestId",
      "storageRef",
      "environmentDigest",
      "modelRef",
      "connectorRef",
      "agentRef"
    ]
  },
  "executionFlow": [
    "request",
    "plan",
    "approve",
    "execute",
    "monitor",
    "collect",
    "review",
    "settle",
    "receipt",
    "continue"
  ],
  "stateMachines": {
    "task": [
      "draft",
      "planned",
      "awaiting_approval",
      "queued",
      "running",
      "review_required",
      "review_blocked",
      "completed",
      "failed",
      "cancelled",
      "archived"
    ],
    "job": [
      "queued",
      "provisioning",
      "running",
      "collecting",
      "succeeded",
      "failed",
      "cancelled",
      "timed_out"
    ],
    "receipt": [
      "planned",
      "approved",
      "running",
      "completed",
      "failed",
      "timed_out",
      "cancelled",
      "review_required",
      "review_blocked"
    ],
    "syncEvent": [
      "accepted",
      "conflict",
      "resolved"
    ]
  },
  "writeEnvelope": {
    "requiredFields": [
      "operationId",
      "idempotencyKey",
      "actor",
      "organizationId",
      "workspaceId",
      "clientId",
      "caller",
      "occurredAt"
    ],
    "optionalReferenceFields": [
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId"
    ],
    "concurrency": {
      "field": "baseVersion",
      "conflictError": "conflict",
      "serverVersion": "derived_from_append_only_sync_events",
      "staleAppend": "accepted_with_next_server_version",
      "staleReplace": "append_durable_conflict_without_overwrite"
    },
    "idempotency": {
      "sameKeySameFingerprint": "replay_original_result",
      "sameKeyDifferentFingerprint": "conflict"
    },
    "retry": {
      "timeoutRule": "Query the durable operation before issuing a new operation.",
      "retryableErrors": [
        "retryable_dependency_failure"
      ]
    }
  },
  "errorSemantics": {
    "invalid_request": {
      "httpStatus": 400,
      "retryable": false
    },
    "unauthenticated": {
      "httpStatus": 401,
      "retryable": false
    },
    "forbidden": {
      "httpStatus": 403,
      "retryable": false
    },
    "not_found": {
      "httpStatus": 404,
      "retryable": false
    },
    "conflict": {
      "httpStatus": 409,
      "retryable": false
    },
    "unavailable_dependency": {
      "httpStatus": 422,
      "retryable": false
    },
    "quota_exceeded": {
      "httpStatus": 429,
      "retryable": true
    },
    "retryable_dependency_failure": {
      "httpStatus": 503,
      "retryable": true
    }
  },
  "logicalServiceOperations": {
    "controlPlane": [
      "create_project_identity",
      "create_task_identity",
      "sync_mutation",
      "pull_sync_changes",
      "resolve_sync_conflict",
      "request_execution",
      "record_approval",
      "sync_execution",
      "resolve_execution_continuation"
    ],
    "fabric": [
      "create_job",
      "query_job",
      "cancel_job",
      "claim_job",
      "heartbeat_job",
      "complete_job",
      "fail_job",
      "retry_job"
    ],
    "ledger": [
      "record_artifact_manifest",
      "query_artifact_manifest",
      "record_review",
      "query_review",
      "record_receipt",
      "query_receipt",
      "resolve_continuation"
    ],
    "gateway": [
      "authorize_route",
      "record_usage"
    ]
  },
  "httpApis": {
    "controlPlane": {
      "createProject": "POST /api/projects",
      "createTask": "POST /api/projects/<projectId>/tasks",
      "requestExecution": "POST /api/execution-requests",
      "approveExecution": "POST /api/execution-requests/<requestId>/approve",
      "executeRequest": "POST /api/execution-requests/<requestId>/execute",
      "syncExecution": "POST /api/execution-requests/<requestId>/sync",
      "resolveExecutionContinuation": "GET /api/execution-requests/<requestId>/continuation",
      "queryExecution": "GET /api/execution-requests/<requestId>",
      "pushSyncMutation": "POST /api/workspaces/<workspaceId>/sync/mutations",
      "pullSyncChanges": "GET /api/workspaces/<workspaceId>/sync/changes?after=<cursor>&limit=<n>",
      "resolveSyncConflict": "POST /api/workspaces/<workspaceId>/sync/conflicts/<conflictId>/resolve"
    },
    "fabric": {
      "createJob": "POST /fabric/jobs",
      "queryJob": "GET /fabric/jobs/<jobId>",
      "cancelJob": "POST /fabric/jobs/<jobId>/cancel",
      "claimJob": "POST /fabric/jobs/<jobId>/claim",
      "heartbeatJob": "POST /fabric/jobs/<jobId>/heartbeat",
      "completeJob": "POST /fabric/jobs/<jobId>/complete",
      "failJob": "POST /fabric/jobs/<jobId>/fail",
      "retryJob": "POST /fabric/jobs/<jobId>/retry"
    },
    "ledger": {
      "recordReceipt": "POST /ledger/receipts",
      "queryReceipt": "GET /ledger/receipts/<receiptId>",
      "resolveContinuation": "GET /ledger/receipts/<receiptId>/continuation",
      "recordArtifact": "POST /ledger/artifacts",
      "queryArtifact": "GET /ledger/artifacts/<artifactId>",
      "recordReview": "POST /ledger/reviews",
      "queryReview": "GET /ledger/reviews/<reviewId>"
    }
  },
  "canonicalExample": {
    "organizationId": "org-lab-01",
    "workspaceId": "workspace-lab-01",
    "projectId": "project-research-01",
    "taskId": "task-analysis-01",
    "requestId": "request-run-01",
    "approvalId": "approval-run-01",
    "jobId": "job-run-01",
    "artifactId": "artifact-result-01",
    "reviewId": "review-result-01",
    "receipt": {
      "receiptId": "receipt-run-01",
      "status": "completed",
      "projectId": "project-research-01",
      "taskId": "task-analysis-01",
      "requestId": "request-run-01",
      "approvalId": "approval-run-01",
      "jobId": "job-run-01",
      "artifactIds": [
        "artifact-result-01"
      ],
      "reviewIds": [
        "review-result-01"
      ],
      "continuationId": "continuation-run-01"
    },
    "continuation": {
      "continuationId": "continuation-run-01",
      "receiptId": "receipt-run-01",
      "projectId": "project-research-01",
      "taskId": "task-analysis-01"
    }
  }
}
