{
  "schemaVersion": 9,
  "owner": "OPL Console Control Plane",
  "purpose": "Strict source envelopes and customer-safe live projections for Console source-of-truth APIs.",
  "state": "current",
  "machineBoundary": "Source, availability, timestamps, strict DTO fields, tenant identity, and unavailable behavior for Console read APIs.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer approved source-truth contract and matching focused tests."
  },
  "envelope": {
    "typeName": "SourceEnvelope<T>",
    "serverWriter": "writeSourceEnvelope",
    "requiredFields": ["source", "status", "available", "fetchedAt"],
    "statuses": ["available", "empty", "unavailable"],
    "states": {
      "available": { "available": true, "data": "required" },
      "empty": { "available": true, "data": "required_real_zero_rows" },
      "unavailable": { "available": false, "data": "forbidden", "zeroValues": "forbidden", "emptyCollections": "forbidden" }
    },
    "sourceUpdatedAt": "optional_only_when_returned_by_authoritative_upstream",
    "fetchedAtMaySubstituteSourceUpdatedAt": false,
    "httpSemantics": {
      "upstreamUnavailable": [500, 502],
      "authentication": [401, 403],
      "unavailableBody": "strict_unavailable_envelope"
    }
  },
  "implementationEvidence": {
    "generalKeys": "code_complete_local_focused_tests",
    "operatorProjection": "base_projection_local_tests_workspace_launch_recovery_fields_pending_integration",
