{
  "schemaVersion": 5,
  "owner": "OPL Ledger",
  "purpose": "General execution evidence receipts and current control-plane lifecycle receipts.",
  "state": "current",
  "machineBoundary": "General receipt states, identity, provenance, artifact, review result, review policy and gate, continuation, idempotency, and current receipt API shape.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "currentScope": "general execution receipt v1, Artifact Manifests, Review Results, versioned Review Policies and gates, continuation, and current Workspace lifecycle receipts",
  "receiptTypes": [
    "workspace.created",
    "workspace.compute_stopped",
    "workspace.compute_restarted",
    "workspace.compute_recreated",
    "workspace.compute_destroyed",
    "workspace.storage_backup_created",
    "workspace.storage_restored",
    "workspace.storage_destroyed",
    "workspace.access_token_reset",
    "workspace.access_token_deleted",
    "artifact.manifest.v1",
    "review.result.v1",
    "execution.receipt.v1"
  ],
  "requiredFields": [
    "type",
    "status",
    "surface",
    "workspaceId",
    "Idempotency-Key header"
  ],
  "generalReceiptV1": {
    "api": {
      "record": "POST /ledger/receipts",
      "list": "GET /ledger/receipts",
      "query": "GET /ledger/receipts/<receiptId>",
      "resolveContinuation": "GET /ledger/receipts/<receiptId>/continuation",
      "recordArtifact": "POST /ledger/artifacts",
      "queryArtifact": "GET /ledger/artifacts/<artifactId>",
      "recordReview": "POST /ledger/reviews",
      "queryReview": "GET /ledger/reviews/<reviewId>",
      "createReviewPolicy": "POST /ledger/review-policies",
      "listReviewPolicies": "GET /ledger/review-policies",
      "queryReviewPolicy": "GET /ledger/review-policies/<policyId>",
      "evaluateReviewGate": "POST /ledger/review-gates/evaluate"
    },
    "query": {
      "endpoint": "GET /ledger/receipts",
      "exactFilters": [
        "organizationId",
        "workspaceId",
        "projectId",
        "taskId",
        "jobId",
        "type",
        "status"
      ],
      "order": [
        "createdAt desc",
        "receiptId desc"
      ],
      "pagination": {
        "cursor": "opaque_createdAt_receiptId",
        "defaultLimit": 50,
        "maxLimit": 100
      }
    },
    "statuses": [
      "planned",
      "approved",
      "running",
      "completed",
      "failed",
      "timed_out",
      "cancelled",
      "review_required",
      "review_blocked"
    ],
    "identityFields": [
      "organizationId",
      "workspaceId",
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId"
    ],
    "evidenceChain": [
      "request",
      "plan",
      "approval",
      "execution",
      "environment",
      "inputRefs",
      "outputRefs",
      "reviewerChecks",
      "cost",
      "receipt",
      "continuation"
    ],
    "artifactManifestFields": [
      "artifactId",
      "digest",
      "mediaType",
      "sizeBytes",
      "storageRef",
      "organizationId",
      "workspaceId",
      "projectId",
      "taskId",
      "jobId",
      "createdAt"
    ],
    "reviewResultFields": [
      "reviewId",
      "reviewerRef",
      "reviewerVersion",
      "inputArtifactDigests",
      "checks",
      "decision",
      "organizationId",
      "workspaceId",
      "projectId",
      "taskId",
      "jobId",
      "createdAt"
    ],
    "reviewDecisions": [
      "pending",
      "accepted",
      "rejected"
    ],
    "reviewPolicy": {
      "ownership": "ledger",
      "writeProtocol": "append_new_version_with_idempotency",
      "idempotencyNamespace": "review_policy",
      "statuses": [
        "active",
        "superseded"
      ],
      "scopeFields": [
        "organizationId",
        "workspaceId",
        "projectId",
        "taskId",
        "jobId"
      ],
      "requiredFields": [
        "policyId",
        "version",
        "requiredReviewers[].reviewerRef",
        "requiredReviewers[].reviewerVersion",
        "status",
        "createdAt"
      ]
    },
    "reviewGate": {
      "input": [
        "execution identity",
        "reviewIds"
      ],
      "statuses": [
        "accepted",
        "review_required",
        "review_blocked"
      ],
      "evidence": [
        "missing",
        "pending",
        "rejected",
        "versionMismatches"
      ],
      "continuationRule": "eligible only when status is accepted; a full execution identity without an active policy is ineligible",
      "receiptReadRule": "for a full execution identity, receipt query and list omit continuationId and continuation unless the active review gate is accepted",
      "waiver": "not_supported_without_auditable_signed_policy_decision"
    },
    "continuationFields": [
      "continuationId",
      "receiptId",
      "projectId",
      "taskId",
      "taskVersion",
      "requiredArtifactDigests",
      "artifactIds",
      "reviewIds",
      "environmentRef"
    ],
    "writeProtocol": "append_first_with_idempotency",
    "correctionProtocol": "append_superseding_receipt",
    "forbiddenContent": [
      "rawCredential",
      "token",
      "secret",
      "signedUrl",
      "presignedUrl",
      "objectKey",
      "kubeconfig"
    ]
  },
  "workspaceCreateReceipt": {
    "plan": [
      "workspaceName",
      "packageId",
      "computeProfile",
      "storageGb"
    ],
    "approval": "implicit_console_policy",
    "environment": [
      "runtimeProvider",
      "workspaceImage"
    ],
    "resourceRefs": [
      "serverId",
      "dockerId",
      "storageId",
      "storageMountPath",
      "urlTokenMode",
      "tokenStatus"
    ],
    "billingRefs": [
      "compute_hold",
      "storage_hold",
      "compute_debit",
      "storage_debit"
    ],
    "continuation": {
      "action": "open_workspace_url",
      "requiredFields": [
        "workspaceId",
        "tokenVersion",
        "redactedUrl"
      ],
      "forbiddenContent": [
        "token=",
        "workspace.access.password",
        "full workspace.url"
      ]
    }
  },
  "workspaceTokenResetReceipt": {
    "type": "workspace.access_token_reset",
    "continuation": {
      "action": "open_workspace_url",
      "requiredFields": [
        "workspaceId",
        "tokenVersion",
        "redactedUrl"
      ],
      "forbiddenContent": [
        "token=",
        "workspace.access.password",
        "full workspace.url"
      ]
    }
  },
  "nonGoals": [
    "artifact byte storage ownership",
    "domain reviewer implementation logic",
    "agent package execution",
    "connector credential storage"
  ]
}
