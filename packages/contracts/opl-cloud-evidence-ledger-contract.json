{
  "schemaVersion": 11,
  "owner": "OPL Ledger",
  "purpose": "General execution, monthly billing, and current control-plane lifecycle evidence receipts.",
  "state": "current",
  "machineBoundary": "General receipt states, identity, provenance, artifact, review result, review policy and gate, continuation, idempotency, and current receipt API shape.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "currentScope": "Invite-only Pilot Workspace receipts, reconciliation evidence, and non-customer general execution evidence; retired resource receipts remain historical read-only compatibility.",
  "receiptTypes": [
    "workspace.created",
    "workspace.compute_stopped",
    "workspace.compute_destroyed",
    "workspace.storage_destroyed",
    "workspace.access_token_reset",
    "workspace.access_token_deleted",
    "billing.reconciliation.v1",
    "billing.workspace_purchased.v1",
    "billing.workspace_renewed.v1",
    "billing.workspace_expired.v1",
    "billing.workspace_refunded.v1",
    "gateway.wallet_adjustment.v1",
    "workspace.gateway_key_rotated.v1",
    "artifact.manifest.v1",
    "review.result.v1",
    "execution.receipt.v1"
  ],
  "historicalReadOnlyReceiptCompatibility": {
    "types": [
      "workspace.compute_restarted",
      "workspace.compute_recreated",
      "billing.resource_purchased.v1",
      "billing.resource_renewed.v1",
      "billing.resource_expired.v1",
      "billing.resource_refunded.v1",
      "billing.charge_review_required.v1"
    ],
    "existingReceiptsReadable": true,
    "newWritesAllowed": false
  },
  "requiredFields": [
    "type",
    "status",
    "surface",
    "workspaceId",
    "Idempotency-Key header"
  ],
  "generalReceiptV1": {
    "pilotStatus": "not_exposed_in_invite_only_pilot",
    "api": {
      "record": "POST /ledger/receipts",
      "list": "GET /ledger/receipts",
      "query": "GET /ledger/receipts/<receiptId>",
      "resolveContinuation": "GET /ledger/receipts/<receiptId>/continuation",
      "recordArtifact": "POST /ledger/artifacts",
      "queryArtifact": "GET /ledger/artifacts/<artifactId>",
      "recordReview": "POST /ledger/reviews",
      "queryReview": "GET /ledger/reviews/<reviewId>",
      "createReviewPolicy": "POST /ledger/review-policies",
      "listReviewPolicies": "GET /ledger/review-policies",
      "queryReviewPolicy": "GET /ledger/review-policies/<policyId>",
      "evaluateReviewGate": "POST /ledger/review-gates/evaluate"
    },
    "query": {
      "endpoint": "GET /ledger/receipts",
      "exactFilters": [
        "organizationId",
        "workspaceId",
        "projectId",
        "taskId",
        "jobId",
        "type",
        "status"
      ],
      "order": [
        "createdAt desc",
        "receiptId desc"
      ],
      "pagination": {
        "cursor": "opaque_createdAt_receiptId",
        "defaultLimit": 50,
        "maxLimit": 100
      }
    },
    "statuses": [
      "planned",
      "approved",
      "running",
      "completed",
      "failed",
      "timed_out",
      "cancelled",
      "review_required",
      "review_blocked"
    ],
    "identityFields": [
      "organizationId",
      "workspaceId",
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId"
    ],
    "evidenceChain": [
      "request",
      "plan",
      "approval",
      "execution",
      "environment",
      "inputRefs",
      "outputRefs",
      "reviewerChecks",
      "cost",
      "receipt",
      "continuation"
    ],
    "artifactManifestFields": [
      "artifactId",
      "digest",
      "mediaType",
      "sizeBytes",
      "storageRef",
      "organizationId",
      "workspaceId",
      "projectId",
      "taskId",
      "jobId",
      "createdAt"
    ],
    "reviewResultFields": [
      "reviewId",
      "reviewerRef",
      "reviewerVersion",
      "inputArtifactDigests",
      "checks",
      "decision",
      "organizationId",
      "workspaceId",
      "projectId",
      "taskId",
      "jobId",
      "createdAt"
    ],
    "reviewDecisions": [
      "pending",
      "accepted",
      "rejected"
    ],
    "reviewPolicy": {
      "ownership": "ledger",
      "writeProtocol": "append_new_version_with_idempotency",
      "idempotencyNamespace": "review_policy",
      "statuses": [
        "active",
        "superseded"
      ],
      "scopeFields": [
        "organizationId",
        "workspaceId",
        "projectId",
        "taskId",
        "jobId"
      ],
      "requiredFields": [
        "policyId",
        "version",
        "requiredReviewers[].reviewerRef",
        "requiredReviewers[].reviewerVersion",
        "status",
        "createdAt"
      ]
    },
    "reviewGate": {
      "input": [
        "execution identity",
        "reviewIds"
      ],
      "statuses": [
        "accepted",
        "review_required",
        "review_blocked"
      ],
      "evidence": [
        "missing",
        "pending",
        "rejected",
        "versionMismatches"
      ],
      "continuationRule": "eligible only when status is accepted; a full execution identity without an active policy is ineligible",
      "receiptReadRule": "for a full execution identity, receipt query and list omit continuationId and continuation unless the active review gate is accepted",
      "waiver": "not_supported_without_auditable_signed_policy_decision"
    },
    "continuationFields": [
      "continuationId",
      "receiptId",
      "projectId",
      "taskId",
      "taskVersion",
      "requiredArtifactDigests",
      "artifactIds",
      "reviewIds",
      "environmentRef"
    ],
    "writeProtocol": "append_first_with_idempotency",
    "correctionProtocol": "append_superseding_receipt",
    "forbiddenContent": [
      "apiKey",
      "adminToken",
      "rawSub2apiResponse",
      "rawProviderResponse",
      "rawCredential",
      "password",
      "token",
      "secret",
      "signedUrl",
      "presignedUrl",
      "objectKey",
      "kubeconfig"
    ]
  },
  "workspaceAccessTokenResetReceipt": {
    "type": "workspace.access_token_reset",
    "idempotencyIdentity": "runtime-credential-rotate:<workspaceId>:<request-idempotency-key>",
    "requiredRefs": [
      "runtimeId",
      "computeAllocationId",
      "storageId",
      "credentialVersion",
      "credentialSecretRef",
      "owner.userId"
    ],
    "forbiddenContent": [
      "password",
      "apiKey",
      "rawCredential",
      "rawProviderResponse"
    ]
  },
  "workspaceGatewayKeyRotationReceipt": {
    "type": "workspace.gateway_key_rotated.v1",
    "requiredRefs": ["operationId", "workspaceId", "oldKeyId", "newKeyId", "secretFingerprint"],
    "forbiddenContent": ["apiKey", "rawCredential", "sessionCredential", "rawSub2apiResponse"],
    "implementation": "validator_and_control_plane_exact_readback_code_complete_local_only"
  },
  "gatewayWalletAdjustmentReceipt": {
    "type": "gateway.wallet_adjustment.v1",
    "balanceAuthority": "sub2api",
    "commonRequiredRefs": ["operationId", "kind", "amountUsdMicros", "balanceHistoryRef", "actor"],
    "businessRefundAdditionalRequiredRefs": ["relatedOperationId"],
    "forbiddenContent": ["redeemCode", "adminToken", "rawSub2apiResponse"],
    "implementation": "validator_and_control_plane_exact_readback_code_complete_local_only"
  },
  "monthlyBillingReceiptV1": {
    "status": "superseded_internal_compatibility",
    "types": [
      "billing.resource_purchased.v1",
      "billing.resource_renewed.v1",
      "billing.resource_expired.v1",
      "billing.resource_refunded.v1",
      "billing.charge_review_required.v1"
    ],
    "requiredCostFields": [
      "pricingVersion",
      "monthlyPriceCnyCents",
      "chargeUsdMicros",
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "periodStart",
      "paidThrough",
      "resourceType",
      "resourceId"
    ],
    "costFieldTypes": {
      "pricingVersion": "non_empty_opaque_string",
      "monthlyPriceCnyCents": "non_negative_integer",
      "chargeUsdMicros": "non_negative_integer",
      "sub2apiUserId": "positive_integer",
      "sub2apiRedeemCode": "non_empty_opaque_string",
      "periodStart": "RFC3339_string",
      "paidThrough": "RFC3339_string",
      "resourceType": "non_empty_opaque_string",
      "resourceId": "non_empty_opaque_string"
    },
    "existingReceiptsReadable": true,
    "newWritesAllowed": false,
    "writeProtocol": "forbidden",
    "correctionProtocol": "historical_receipts_are_immutable",
    "forbiddenContentRule": "reject recursively by case-insensitive exact field name in maps, slices, and typed JSON containers; token-count fields such as inputTokens remain allowed",
    "forbiddenContent": [
      "apiKey",
      "adminToken",
      "rawSub2apiResponse",
      "rawProviderResponse",
      "password",
      "token"
    ]
  },
  "billingReconciliationReceiptV1": {
    "type": "billing.reconciliation.v1",
    "requiredCostFields": [
      "pricingVersion",
      "monthlyPriceCnyCents",
      "chargeUsdMicros",
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "periodStart",
      "paidThrough",
      "resourceType",
      "resourceId"
    ],
    "writeProtocol": "append_first_with_idempotency"
  },
  "workspaceMonthlyBillingReceiptV1": {
    "types": [
      "billing.workspace_purchased.v1",
      "billing.workspace_renewed.v1",
      "billing.workspace_expired.v1",
      "billing.workspace_refunded.v1"
    ],
    "requiredCostFields": [
      "priceVersion",
      "currency",
      "billingUnit",
      "totalUsdMicros",
      "periodStart",
      "paidThrough",
      "resourceType",
      "resourceId",
      "components"
    ],
    "purchasedAdditionalCostFields": [
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "postChargeBalanceUsdMicros"
    ],
    "renewedAdditionalCostFields": [
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "postChargeBalanceUsdMicros"
    ],
    "refundedAdditionalCostFields": [
      "sub2apiUserId",
      "sub2apiRedeemCode",
      "sub2apiRefundCode",
      "refundUsdMicros"
    ],
    "exactComponents": {
      "compute": ["resourceType", "resourceId", "chargeUsdMicros"],
      "storage": ["resourceType", "resourceId", "sizeGb", "chargeUsdMicros"]
    },
    "purchasedRequiredExecutionFields": [
      "computeAllocationId",
      "storageId"
    ],
    "purchasedOptionalExecutionFields": [
      "attachmentId",
      "workspaceApiKeyId",
      "runtimeId"
    ],
    "customerProjectionForbiddenFields": [
      "computeReadback",
      "storageReadback",
      "workspaceKeyFingerprint",
      "runtimeServiceName",
      "secretRef"
    ],
    "rules": [
      "currency is USD and billingUnit is calendar_month",
      "resourceType is workspace",
      "cost.resourceId equals receipt workspaceId",
      "all money and size fields are integers with positive component amounts",
      "totalUsdMicros equals compute plus storage with int64 overflow rejection",
      "paidThrough is strictly after periodStart",
      "expired receipts contain no synthetic Sub2API charge identity",
      "refunded receipts require the original debit identity, a stable refund identity, and refundUsdMicros equal to totalUsdMicros"
    ],
    "writeProtocol": "append_first_with_idempotency",
    "launchTerminalCardinality": "exactly_one_purchased_or_refunded_workspace_receipt",
    "forbiddenContentRule": "same recursive case-insensitive exact-key rejection as general receipts",
    "implementation": "validator_writer_and_customer_projection_code_complete_local_tests_only",
    "realEnvironmentEvidence": "pending_owner_approved_acceptance"
  },
  "reconciliationReportV1": {
    "recordApi": "POST /ledger/reconciliation",
    "idempotencyKey": "required_non_blank",
    "requiredReportFields": ["id", "status", "counts", "exceptions"],
    "id": "non_empty_string",
    "statuses": ["ok", "mismatch"],
    "counts": {
      "requiredFields": ["billingOperations", "matched", "exceptions"],
      "allFields": "non_negative_integer"
    },
    "exceptions": {
      "type": "array",
      "requiredFields": ["resourceType", "resourceId", "code"],
      "resourceTypes": ["compute", "storage", "workspace"],
      "resourceId": "non_empty_opaque_string",
      "codes": [
        "billing_operation_invalid",
        "sub2api_balance_history_unavailable",
        "sub2api_charge_missing",
        "sub2api_charge_mismatch",
        "fabric_operations_unavailable",
        "fabric_operation_missing",
        "fabric_operation_mismatch",
        "ledger_receipts_unavailable",
        "ledger_receipt_missing",
        "ledger_receipt_mismatch"
      ]
    },
    "workspaceRenewalAuthority": {
      "customerOperationCardinality": 1,
      "balanceFact": "one_combined_sub2api_charge",
      "providerFacts": ["compute_renewal", "storage_renewal"],
      "receiptType": "billing.workspace_renewed.v1"
    },
    "consistencyRules": [
      "counts.exceptions equals exceptions length",
      "counts.billingOperations equals counts.matched plus unique exception resource count",
      "ok has zero exceptions and does not block new Workspaces",
      "mismatch has at least one exception and blocks new Workspaces"
    ],
    "result": {
      "identity": "id and status equal the submitted report",
      "report": "structurally_equal_to_submitted_report",
      "blockNewWorkspaces": "status_equals_mismatch",
      "reason": "operator_reconciliation"
    },
    "validationOrder": "validate before hash, idempotency lookup, or persistence",
    "replayRule": "validate persisted report and result guard before return",
    "forbiddenContentRule": "same recursive case-insensitive exact-field rule as receipts"
  },
  "workspaceCreateReceipt": {
    "plan": [
      "workspaceName",
      "packageId",
      "computeProfile",
      "storageGb"
    ],
    "approval": "implicit_console_policy",
    "environment": [
      "runtimeProvider",
      "workspaceImage"
    ],
    "resourceRefs": [
      "serverId",
      "dockerId",
      "storageId",
      "storageMountPath",
      "runtimeStatus",
      "credentialStatus"
    ],
    "billingRefs": [
      "billing.workspace_purchased.v1",
      "sub2apiRedeemCode",
      "paidThrough"
    ],
    "continuation": {
      "action": "open_workspace_url",
      "requiredFields": [
        "workspaceId",
        "redactedUrl"
      ],
      "forbiddenContent": [
        "workspace.access.password",
        "full workspace.url"
      ]
    }
  },
  "nonGoals": [
    "workspace backup recovery sync or transfer evidence",
    "artifact byte storage ownership",
    "domain reviewer implementation logic",
    "agent package execution",
    "connector credential storage"
  ]
}
