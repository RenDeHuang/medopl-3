{
  "schemaVersion": 2,
  "owner": "OPL Ledger",
  "purpose": "General execution evidence receipts and current control-plane lifecycle receipts.",
  "state": "current",
  "machineBoundary": "General receipt states, identity, provenance, artifact, review, continuation, idempotency, and current receipt API shape.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "currentScope": "general execution receipt v1 plus current Workspace lifecycle and task evidence receipts",
  "receiptTypes": [
    "workspace.created",
    "workspace.compute_stopped",
    "workspace.compute_restarted",
    "workspace.compute_recreated",
    "workspace.compute_destroyed",
    "workspace.storage_backup_created",
    "workspace.storage_restored",
    "workspace.storage_destroyed",
    "workspace.access_token_reset",
    "workspace.access_token_deleted",
    "execution.receipt.v1",
    "task.evidence.v1"
  ],
  "requiredFields": [
    "id",
    "type",
    "accountId",
    "workspaceId",
    "actor",
    "plan",
    "approval",
    "environment",
    "resourceRefs",
    "billingRefs",
    "inputRefs",
    "executionRefs",
    "outputRefs",
    "reviewResults",
    "createdAt"
  ],
  "generalReceiptV1": {
    "statuses": [
      "planned",
      "approved",
      "running",
      "completed",
      "failed",
      "cancelled",
      "review_required",
      "review_blocked"
    ],
    "identityFields": [
      "organizationId",
      "workspaceId",
      "projectId",
      "taskId",
      "requestId",
      "approvalId",
      "jobId",
      "artifactId",
      "reviewId",
      "receiptId",
      "continuationId"
    ],
    "evidenceChain": [
      "request",
      "plan",
      "approval",
      "execution",
      "environment",
      "inputRefs",
      "outputRefs",
      "reviewerChecks",
      "cost",
      "receipt",
      "continuation"
    ],
    "artifactManifestFields": [
      "artifactId",
      "digest",
      "mediaType",
      "sizeBytes",
      "storageRef",
      "createdAt"
    ],
    "reviewResultFields": [
      "reviewId",
      "reviewerRef",
      "reviewerVersion",
      "inputArtifactDigests",
      "checks",
      "decision",
      "createdAt"
    ],
    "continuationFields": [
      "continuationId",
      "receiptId",
      "projectId",
      "taskId",
      "taskVersion",
      "requiredArtifactDigests",
      "environmentRef"
    ],
    "writeProtocol": "append_first_with_idempotency",
    "correctionProtocol": "append_superseding_receipt",
    "forbiddenContent": [
      "rawCredential",
      "token",
      "secret",
      "signedUrl",
      "presignedUrl",
      "objectKey",
      "kubeconfig"
    ]
  },
  "workspaceCreateReceipt": {
    "plan": [
      "workspaceName",
      "packageId",
      "computeProfile",
      "storageGb"
    ],
    "approval": "implicit_console_policy",
    "environment": [
      "runtimeProvider",
      "workspaceImage"
    ],
    "resourceRefs": [
      "serverId",
      "dockerId",
      "storageId",
      "storageMountPath",
      "urlTokenMode",
      "tokenStatus"
    ],
    "billingRefs": [
      "compute_hold",
      "storage_hold",
      "compute_debit",
      "storage_debit"
    ],
    "continuation": {
      "action": "open_workspace_url",
      "requiredFields": [
        "workspaceId",
        "tokenVersion",
        "redactedUrl"
      ],
      "forbiddenContent": [
        "token=",
        "workspace.access.password",
        "full workspace.url"
      ]
    }
  },
  "workspaceTokenResetReceipt": {
    "type": "workspace.access_token_reset",
    "continuation": {
      "action": "open_workspace_url",
      "requiredFields": [
        "workspaceId",
        "tokenVersion",
        "redactedUrl"
      ],
      "forbiddenContent": [
        "token=",
        "workspace.access.password",
        "full workspace.url"
      ]
    }
  },
  "taskEvidenceReceiptV1": {
    "api": {
      "record": "POST /api/ledger/task-receipts",
      "query": "GET /api/ledger/task-receipts?accountId=<accountId>&workspaceId=<workspaceId>&taskId=<taskId>"
    },
    "requiredFields": [
      "accountId",
      "taskId",
      "plan",
      "approval",
      "environment"
    ],
    "refs": [
      "inputRefs",
      "executionRefs",
      "outputRefs"
    ],
    "review": "reviewResults",
    "continuation": "continue_task",
    "ownershipRule": "workspaceId must belong to accountId when provided",
    "appendOnlyState": "evidenceLedger"
  },
  "nonGoals": [
    "artifact byte storage ownership",
    "domain reviewer implementation logic",
    "agent package execution",
    "connector credential storage"
  ]
}
