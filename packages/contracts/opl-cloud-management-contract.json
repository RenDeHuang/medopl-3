{
  "schemaVersion": 16,
  "owner": "OPL Console",
  "purpose": "Console customer identity, strict owner graph, Sub2API authentication authority, lifecycle, and management API contract.",
  "state": "current",
  "machineBoundary": "One Console User, one OPL Account, and one Sub2API User/Wallet per invited customer; Organization and Membership are internal one-to-one compatibility records only.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "pilotCohort": {
    "mode": "invite_only",
    "minimumCustomerAccounts": 2,
    "maximumCustomerAccounts": 5,
    "publicRegistration": false
  },
  "entities": {
    "account": {
      "requiredFields": [
        "id",
        "ownerUserId",
        "status",
        "sub2apiUserId",
        "createdAt",
        "updatedAt"
      ],
      "sub2apiMapping": "sub2apiUserId is a required positive integer and is the only spendable-balance identity."
    },
    "user": {
      "requiredFields": [
        "id",
        "email",
        "accountId",
        "role",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "roles": ["owner"]
    },
    "organization": {
      "requiredFields": [
        "id",
        "name",
        "billingAccountId",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "pilotRole": "internal_one_to_one_compatibility",
      "authorizationAuthority": false
    },
    "membership": {
      "requiredFields": [
        "id",
        "organizationId",
        "accountId",
        "userId",
        "role",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "roles": ["owner"],
      "pilotRole": "internal_one_to_one_compatibility",
      "authorizationAuthority": false
    },
    "supportTicketMapping": {
      "requiredFields": [
        "id",
        "externalSystem",
        "externalTicketId",
        "externalUrl",
        "accountId",
        "workspaceId",
        "resourceIds",
        "operationId",
        "title",
        "category",
        "priority",
        "status",
        "createdAt",
        "updatedAt",
        "messages"
      ]
    }
  },
  "customerIdentityGraph": {
    "cardinality": "exactly_one_console_user_account_sub2api_user_wallet",
    "accountUser": "account.ownerUserId_equals_user.id_and_user.accountId_equals_account.id",
    "sub2apiIdentity": "account.sub2apiUserId_equals_the_single_remote_user_id_and_wallet_owner",
    "normalizedEmail": "lower_trim_console_email_equals_lower_trim_sub2api_email",
    "customerRole": "owner_only",
    "customerAccess": "session_user_owns_account_and_remote_identity_is_active",
    "operatorException": "fixed_usr_admin_on_acct_admin_uses_admin_role_outside_customer_graph"
  },
  "internalCompatibilityRecords": {
    "organizationAndMembership": "one_to_one_storage_only",
    "customerAuthorizationAuthority": false,
    "browserProjection": false,
    "sharedBehavior": false,
    "mutationRoutes": "retired"
  },
  "workspaceOwnership": {
    "personalWorkspace": "ownerAccountId identifies the Console owner and its Sub2API mapping."
  },
  "identityProvisioning": {
    "onlyMutation": "POST /api/operator/accounts",
    "requestType": "ProvisionAccountRequest",
    "semantics": {
      "command": "provision",
      "operatorLanguage": "open",
      "auditAction": "account.provision",
      "operationIdPrefix": "account-provision"
    },
    "atomicProvision": "After Sub2API resolves or creates and re-reads the remote identity, one transaction commits the mapped Account and normalized owner User plus internal one-to-one Organization/Membership compatibility rows.",
    "atomicFacts": ["account", "user", "organization", "membership"],
    "callerSuppliedSub2apiUserId": "forbidden",
    "partialFailure": "rollback_all_four_facts",
    "matchingReplay": "return_existing_graph_without_duplicate_facts",
    "mismatch": "fail_closed_without_mutation"
  },
  "identitySecurity": {
    "email": "Provision and bootstrap normalize email with lower(trim(email)); normalized email is unique in PostgreSQL and legacy blank or colliding values fail migration closed.",
    "plaintextPasswordMinimumCharacters": 12,
    "passwordAuthority": "sub2api",
    "provisionPasswordHandling": "forward_to_sub2api_only_never_persist",
    "localPasswordHash": {
      "column": "control_plane_users.password_hash",
      "requiredValue": "",
      "enforcement": "database_check_constraint"
    },
    "sessionLookupKeyPrefix": "sub2api-sha256:",
    "delegatedGatewayCredential": {
      "authority": "sub2api_login_access_token",
      "storage": "control_plane_process_memory_only",
      "index": "hashed_session_lookup_key",
      "lifetime": "bounded_by_console_session",
      "missingOrExpired": "401_reauthentication_required_and_cookie_clear",
      "forbidden": ["browser", "postgresql", "ledger", "logs"]
    },
    "secretProjection": "Passwords and password hashes are excluded from browser responses and audit facts."
  },
  "bootstrapLifecycle": {
    "operatorProvisioning": "A fresh PostgreSQL database reads the fixed Sub2API operator identity and atomically commits its Account/User mapping plus internal compatibility rows.",
    "legacyLocalUsersEnv": "retired_nonempty_value_fails_startup"
  },
  "identityDelivery": {
    "controlPlane": "canonical_provisioning_integrated_local_verified",
    "deploymentCutover": "canonical_route_deployment_pending",
    "authenticatedRuntimeEvidence": "pending"
  },
  "userLifecycle": {
    "sessionPolicy": "Disabling or deleting a User revokes that User's sessions and process-local delegated Gateway credentials.",
    "ownerRenewalPolicy": "Disabling or deleting an owner turns off the Workspace autoRenew intent without deleting provider resources."
  },
  "api": {
    "createAccount": "POST /api/operator/accounts (canonical owner provision only)",
    "operatorAccounts": {
      "list": "GET /api/operator/accounts",
      "provision": "POST /api/operator/accounts",
      "disable": "POST /api/operator/accounts/{accountId}/disable",
      "delete": false
    },
    "operatorReads": {
      "overview": "GET /api/operator/overview",
      "accounts": "GET /api/operator/accounts",
      "workspaces": "GET /api/operator/workspaces",
      "workspaceDetail": "GET /api/operator/workspaces/{workspaceId}",
      "reconciliation": "GET /api/operator/reconciliation",
      "health": "GET /api/operator/health"
    },
    "managementState": "GET /api/management/state",
    "managementStateExcludedFields": ["organization", "organizations", "memberships"],
    "unsupportedMutations": [
      "POST /api/organizations",
      "POST /api/organizations/members",
      "POST /api/organizations/members/{id}/revoke",
      "POST /api/users/{id}/reset-password"
    ],
    "supportTicketMappings": "GET /api/support/tickets",
    "createSupportTicketMapping": "POST /api/support/tickets"
  },
  "operatorProjection": {
    "sub2apiReads": {
      "users": "GET /api/v1/admin/users",
      "usersUsage": "POST /api/v1/admin/dashboard/users-usage",
      "apiKeysUsage": "POST /api/v1/admin/dashboard/api-keys-usage",
      "currentPageKeyCounts": "GET /api/v1/admin/users/{userId}/api-keys",
      "batchSizeMax": 50
    },
    "usersPagination": "collect_all_coherent_sub2api_user_pages",
    "pageSizeMax": 50,
    "perAccountUserOrUsageNPlusOne": false,
    "keyCountRead": "selected_control_plane_page_only_bounded_concurrency_max_4",
    "keyCountPersistence": "none_request_join_only",
    "persistence": "none_request_join_only",
    "readReplica": false,
    "partialFailure": "affected_nested_source_unavailable_without_zero_data",
    "sourceUpdatedAt": "only_authoritative_sub2api_or_ledger_timestamp_never_fetched_at",
    "implementation": "code_complete_local_focused_tests"
  },
  "walletAdjustments": {
    "routes": {
      "create": "POST /api/operator/accounts/{accountId}/wallet-adjustments",
      "read": "GET /api/operator/wallet-adjustments/{operationId}",
      "recover": "POST /api/operator/wallet-adjustments/{operationId}/recover"
    },
    "kinds": ["recharge", "debit", "business_refund"],
    "balanceAuthority": "sub2api",
    "serializationContract": "opl-cloud-service-boundary-contract.json#services.controlPlane.walletMutationSerialization",
    "operationIdentity": "stable_from_account_id_and_idempotency_key",
    "authoritativeReadback": [
      "sub2api_balance_history_exact_code_user_type_signed_amount_used",
      "sub2api_user_balance_exact_expected_after"
    ],
    "unknownResult": "manual_review_without_automatic_replay",
    "manualReviewRecovery": {
      "eligibleStatus": "manual_review",
      "allowedAction": "recover_wallet_adjustment",
      "requestFields": ["accountId", "evidenceRef"],
      "identityReuse": ["original_operation_id", "stable_recovery_intent"],
      "legacyV1Identity": "read_only_history_identity_never_payload_or_idempotency_key",
      "canonicalV2Identity": "\"opl:\" + stableID(\"sub2api-wallet-adjustment-v2\", operationID)[:28]",
      "canonicalV2Length": 32,
      "preWriteAuthority": "legacy_and_v2_history_absent_unchanged_before_balance_empty_receipt_and_balance_history_ref_no_prior_recovery_write",
      "persistBeforeWrite": ["canonical_v2_identity", "identity_version", "legacy_supersession_status", "operator", "authorized_at", "evidence_ref", "stable_recovery_intent"],
      "maximumRecoveryMoneyWrites": 1,
      "unknownRecoveryResult": "manual_review_without_second_v2_write"
    },
    "upstreamFailureProjection": {
      "fields": ["phase", "httpStatus", "errorCode", "requestId"],
      "rawBody": false,
      "message": false
    },
    "statePersistence": "control_plane_runtime_operations_non_authoritative",
    "evidence": ["control_plane_admin_audit", "ledger_reference"],
    "implementation": "code_complete_local_focused_tests"
  },
  "announcements": {
    "owner": "control_plane_postgresql",
    "tables": ["control_plane_announcements", "control_plane_announcement_reads"],
    "states": ["draft", "scheduled", "published", "withdrawn"],
    "audience": "all_pilot_users",
    "scheduler": false,
    "implementation": "code_complete_local_focused_tests"
  },
  "operatorAuthPolicy": {
    "operatorOverview": "GET /api/operator/overview",
    "genericOperatorTokenAccepted": false,
    "providerAcceptanceCredential": "x-opl-provider-acceptance-token header only",
    "queryTokenAllowed": false,
    "adminSessionAllowed": true,
    "defaultRoute": "/console/overview",
    "consoleRouteBehavior": "owner_console_access",
    "navigation": "customer_routes_then_admin_routes",
    "accountPageLabel": "客户与计费账户",
    "reservedAdminAccountInCustomerRows": true,
    "reservedAdminSelfDisable": "forbidden_frontend_and_backend",
    "otherAccountSecretAccess": "forbidden"
  },
  "operatorBillingReviewProjection": {
    "included": ["workspace.launch.v2_manual_review", "workspace.renewal_manual_review", "BillingReconciliation_mismatch"],
    "nonBillingRuntimeOperations": "excluded",
    "mismatchRecoveryAction": false
  },
  "operatorNotifications": {
    "source": "Derived from current Workspace launch and renewal operations; historical compute and storage billing rows are inert and never create alerts.",
    "activeCodes": [
      "manual_review",
      "past_due",
      "ledger_receipt_pending",
      "cleanup_failed",
      "insufficient",
      "renewal_retry_pending",
      "renewal_receipt_pending",
      "refund_receipt_pending",
      "expiry_receipt_pending",
      "cleanup_pending"
    ],
    "severity": {
      "error": [
        "manual_review",
        "cleanup_failed",
        "cleanup_pending"
      ],
      "warning": [
        "past_due",
        "ledger_receipt_pending",
        "insufficient",
        "renewal_retry_pending",
        "renewal_receipt_pending",
        "refund_receipt_pending",
        "expiry_receipt_pending"
      ]
    },
    "logPolicy": "State transitions use stable codes and hashed resource references; account IDs, resource IDs, redeem codes, balances, credentials, and provider errors are excluded."
  }
}
