{
  "schemaVersion": 1,
  "owner": "OPL Console",
  "purpose": "Commercial identity, organization, membership, role, billing ownership, and user wallet management model.",
  "state": "current",
  "machineBoundary": "User, organization, membership, billing owner, wallet, role, disabled status, and management API shape.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "entities": {
    "organization": {
      "requiredFields": [
        "id",
        "name",
        "billingAccountId",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "user": {
      "requiredFields": [
        "id",
        "email",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "membership": {
      "requiredFields": [
        "id",
        "organizationId",
        "userId",
        "role",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "roles": [
        "owner",
        "admin",
        "member"
      ]
    },
    "billingAccount": {
      "source": "billing ownership identity used by Workspaces and Ledger records",
      "walletTruth": "users",
      "walletFields": [
        "balance",
        "frozen",
        "holds",
        "totalRecharged"
      ],
      "fundingOrder": [
        "available_balance",
        "frozen_hold"
      ],
      "compatibilityAliasAllowed": false
    },
    "supportTicketMapping": {
      "requiredFields": [
        "id",
        "externalSystem",
        "externalTicketId",
        "externalUrl",
        "accountId",
        "userId",
        "workspaceId",
        "resourceIds",
        "operationId",
        "title",
        "category",
        "priority",
        "status",
        "createdAt",
        "updatedAt",
        "messages"
      ],
      "visibility": [
        "Lab Owner sees external support mappings scoped to their account.",
        "Admin sees all external support ticket mappings."
      ],
      "workspaceReferencePolicy": [
        "A mapping may omit workspaceId.",
        "A mapping with workspaceId must reference a Workspace owned by the mapping accountId."
      ]
    }
  },
  "workspaceOwnership": {
    "personalWorkspace": "ownerAccountId is the user billing account id and userId identifies the wallet owner",
    "organizationWorkspace": "ownerAccountId is organization.billingAccountId and userId must have active membership"
  },
  "api": {
    "createOrganization": "POST /api/organizations",
    "createUser": "POST /api/users",
    "addOrganizationMember": "POST /api/organizations/members",
    "managementState": "GET /api/management/state?organizationId=<id>",
    "manualTopUp": "POST /api/billing/topups",
    "supportTicketMappings": "GET /api/support/tickets",
    "createSupportTicketMapping": "POST /api/support/tickets"
  },
  "operatorAuthPolicy": {
    "operatorSummary": "GET /api/operator/summary",
    "machineTokenTransport": "x-opl-operator-token header only",
    "queryTokenAllowed": false,
    "adminSessionAllowed": true
  },
  "adminMutationSafety": {
    "manualTopUp": {
      "requiresClientIdempotencyKey": true,
      "replayMustNotDoubleCredit": true
    },
    "cleanupWorkspaceAccessAll": {
      "api": "POST /api/operator/cleanup-workspace-access",
      "requiresConfirmation": true,
      "requiresCandidatePreviewCount": true,
      "deletesCloudResources": false
    }
  }
}
