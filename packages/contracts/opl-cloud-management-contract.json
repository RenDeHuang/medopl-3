{
  "schemaVersion": 8,
  "owner": "OPL Console",
  "purpose": "Console customer identity, strict owner graph, Sub2API authentication authority, lifecycle, and management API contract.",
  "state": "current",
  "machineBoundary": "One Console User, one OPL Account, and one Sub2API User/Wallet per invited customer; Organization and Membership are internal one-to-one compatibility records only.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "pilotCohort": {
    "mode": "invite_only",
    "minimumCustomerAccounts": 2,
    "maximumCustomerAccounts": 5,
    "publicRegistration": false
  },
  "entities": {
    "account": {
      "requiredFields": [
        "id",
        "ownerUserId",
        "status",
        "sub2apiUserId",
        "createdAt",
        "updatedAt"
      ],
      "sub2apiMapping": "sub2apiUserId is a required positive integer and is the only spendable-balance identity."
    },
    "user": {
      "requiredFields": [
        "id",
        "email",
        "accountId",
        "role",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "roles": ["owner"]
    },
    "organization": {
      "requiredFields": [
        "id",
        "name",
        "billingAccountId",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "pilotRole": "internal_one_to_one_compatibility",
      "authorizationAuthority": false
    },
    "membership": {
      "requiredFields": [
        "id",
        "organizationId",
        "accountId",
        "userId",
        "role",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "roles": ["owner"],
      "pilotRole": "internal_one_to_one_compatibility",
      "authorizationAuthority": false
    },
    "supportTicketMapping": {
      "requiredFields": [
        "id",
        "externalSystem",
        "externalTicketId",
        "externalUrl",
        "accountId",
        "workspaceId",
        "resourceIds",
        "operationId",
        "title",
        "category",
        "priority",
        "status",
        "createdAt",
        "updatedAt",
        "messages"
      ]
    }
  },
  "customerIdentityGraph": {
    "cardinality": "exactly_one_console_user_account_sub2api_user_wallet",
    "accountUser": "account.ownerUserId_equals_user.id_and_user.accountId_equals_account.id",
    "sub2apiIdentity": "account.sub2apiUserId_equals_the_single_remote_user_id_and_wallet_owner",
    "normalizedEmail": "lower_trim_console_email_equals_lower_trim_sub2api_email",
    "customerRole": "owner_only",
    "customerAccess": "session_user_owns_account_and_remote_identity_is_active",
    "operatorException": "fixed_usr_admin_on_acct_admin_uses_admin_role_outside_customer_graph"
  },
  "internalCompatibilityRecords": {
    "organizationAndMembership": "one_to_one_storage_only",
    "customerAuthorizationAuthority": false,
    "browserProjection": false,
    "sharedBehavior": false,
    "mutationRoutes": "retired"
  },
  "workspaceOwnership": {
    "personalWorkspace": "ownerAccountId identifies the Console owner and its Sub2API mapping."
  },
  "identityProvisioning": {
    "onlyMutation": "POST /api/users",
    "atomicInvite": "After Sub2API resolves or creates and re-reads the remote identity, one transaction commits the mapped Account and normalized owner User plus internal one-to-one Organization/Membership compatibility rows.",
    "atomicFacts": ["account", "user", "organization", "membership"],
    "callerSuppliedSub2apiUserId": "forbidden",
    "partialFailure": "rollback_all_four_facts",
    "matchingReplay": "return_existing_graph_without_duplicate_facts",
    "mismatch": "fail_closed_without_mutation"
  },
  "identitySecurity": {
    "email": "Create and bootstrap normalize email with lower(trim(email)); normalized email is unique in PostgreSQL and legacy blank or colliding values fail migration closed.",
    "plaintextPasswordMinimumCharacters": 12,
    "passwordAuthority": "sub2api",
    "invitePasswordHandling": "forward_to_sub2api_only_never_persist",
    "localPasswordHash": {
      "column": "control_plane_users.password_hash",
      "requiredValue": "",
      "enforcement": "database_check_constraint"
    },
    "sessionLookupKeyPrefix": "sub2api-sha256:",
    "secretProjection": "Passwords and password hashes are excluded from browser responses and audit facts."
  },
  "bootstrapLifecycle": {
    "operatorProvisioning": "A fresh PostgreSQL database reads the fixed Sub2API operator identity and atomically commits its Account/User mapping plus internal compatibility rows.",
    "legacyLocalUsersEnv": "retired_nonempty_value_fails_startup"
  },
  "identityDelivery": {
    "controlPlane": "code_complete_local_verification",
    "deploymentCutover": "code_complete_local_verification",
    "authenticatedRuntimeEvidence": "pending"
  },
  "userLifecycle": {
    "sessionPolicy": "Disabling or deleting a User revokes that User's sessions.",
    "ownerRenewalPolicy": "Disabling or deleting an owner turns off the Workspace autoRenew intent without deleting provider resources."
  },
  "api": {
    "createAccount": "POST /api/users (atomic owner invite only)",
    "managementState": "GET /api/management/state",
    "managementStateExcludedFields": ["organization", "organizations", "memberships"],
    "unsupportedMutations": [
      "POST /api/organizations",
      "POST /api/organizations/members",
      "POST /api/organizations/members/{id}/revoke",
      "POST /api/users/{id}/reset-password"
    ],
    "supportTicketMappings": "GET /api/support/tickets",
    "createSupportTicketMapping": "POST /api/support/tickets"
  },
  "operatorAuthPolicy": {
    "operatorSummary": "GET /api/operator/summary",
    "genericOperatorTokenAccepted": false,
    "providerAcceptanceCredential": "x-opl-provider-acceptance-token header only",
    "queryTokenAllowed": false,
    "adminSessionAllowed": true,
    "productionNetworkGate": {
      "allowlistEnv": "OPL_OPERATOR_CIDRS",
      "trustedProxyEnv": "OPL_TRUSTED_PROXY_CIDRS",
      "forwardedHeaderPolicy": "trust_only_from_direct_trusted_proxy_then_strip_right_to_left_to_first_untrusted_client",
      "invalidConfiguration": "fail_closed"
    }
  },
  "operatorNotifications": {
    "source": "Derived from current Workspace renewal operations plus current compute and storage compatibility state; no alert table or second source of truth.",
    "activeCodes": [
      "manual_review",
      "past_due",
      "ledger_receipt_pending",
      "cleanup_failed",
      "insufficient",
      "renewal_retry_pending",
      "renewal_receipt_pending",
      "refund_receipt_pending",
      "expiry_receipt_pending",
      "cleanup_pending"
    ],
    "severity": {
      "error": [
        "manual_review",
        "cleanup_failed",
        "cleanup_pending"
      ],
      "warning": [
        "past_due",
        "ledger_receipt_pending",
        "insufficient",
        "renewal_retry_pending",
        "renewal_receipt_pending",
        "refund_receipt_pending",
        "expiry_receipt_pending"
      ]
    },
    "logPolicy": "State transitions use stable codes and hashed resource references; account IDs, resource IDs, redeem codes, balances, credentials, and provider errors are excluded."
  }
}
