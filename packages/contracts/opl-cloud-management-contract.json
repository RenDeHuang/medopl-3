{
  "schemaVersion": 2,
  "owner": "OPL Console",
  "purpose": "Console identity, organization, membership, role, Sub2API account mapping, and management API contract.",
  "state": "current",
  "machineBoundary": "Account, organization, membership, role, disabled status, Sub2API user mapping, and management API shape.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "entities": {
    "account": {
      "requiredFields": [
        "id",
        "email",
        "role",
        "status",
        "sub2apiUserId",
        "createdAt",
        "updatedAt"
      ],
      "sub2apiMapping": "sub2apiUserId is a required positive integer and is the only spendable-balance identity."
    },
    "organization": {
      "requiredFields": [
        "id",
        "name",
        "billingAccountId",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "membership": {
      "requiredFields": [
        "id",
        "organizationId",
        "accountId",
        "role",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "roles": [
        "owner",
        "admin",
        "member"
      ]
    },
    "supportTicketMapping": {
      "requiredFields": [
        "id",
        "externalSystem",
        "externalTicketId",
        "externalUrl",
        "accountId",
        "workspaceId",
        "resourceIds",
        "operationId",
        "title",
        "category",
        "priority",
        "status",
        "createdAt",
        "updatedAt",
        "messages"
      ]
    }
  },
  "workspaceOwnership": {
    "personalWorkspace": "ownerAccountId identifies the Console owner and its Sub2API mapping.",
    "organizationWorkspace": "ownerAccountId is organization.billingAccountId and the caller must have active membership."
  },
  "api": {
    "createOrganization": "POST /api/organizations",
    "createAccount": "POST /api/users",
    "addOrganizationMember": "POST /api/organizations/members",
    "managementState": "GET /api/management/state?organizationId=<id>",
    "supportTicketMappings": "GET /api/support/tickets",
    "createSupportTicketMapping": "POST /api/support/tickets"
  },
  "operatorAuthPolicy": {
    "operatorSummary": "GET /api/operator/summary",
    "machineTokenTransport": "x-opl-operator-token header only",
    "queryTokenAllowed": false,
    "adminSessionAllowed": true
  }
}
