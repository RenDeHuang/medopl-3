{
  "schemaVersion": 5,
  "owner": "OPL Fabric",
  "purpose": "Expose productized resource choices to OPL Console without making Console own cloud resource inventory.",
  "state": "current",
  "machineBoundary": "Workspace packages, storage classes, ingress domains, and availability flags.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "endpoint": "GET /fabric/catalog",
  "catalogSections": [
    "workspacePackages",
    "storageClasses",
    "ingressDomains"
  ],
  "workspacePackageRules": {
    "consoleSelectableOnlyWhen": "available=true",
    "unavailableError": "package_unavailable:<packageId>:<reason>"
  },
  "supportedPackages": [
    "basic",
    "pro"
  ],
  "productionAvailability": {
    "basic": true,
    "pro": true,
    "authority": "GET /fabric/catalog workspacePackages[].available"
  },
  "availabilityAuthority": "GET /fabric/catalog workspacePackages[].available",
  "availabilityMeaning": "product_open_not_tencent_capacity",
  "capacityAuthority": "Tencent MonthlyPreflight immediately before first debit",
  "pilotV2": {
    "computeAndStorageRole": "workspace_fulfillment_only",
    "customerChargeAuthority": false
  },
  "readinessSurface": {
    "endpoint": "GET /api/runtime/readiness",
    "field": "resourceCatalog"
  }
}
