# OPL Cloud runtime provider
OPL_RUNTIME_PROVIDER=tencent-tke
OPL_PUBLIC_URL=http://127.0.0.1:8787
OPL_WORKSPACE_IMAGE=ghcr.io/gaofeng21cn/one-person-lab-app:latest

# Runtime uses Tencent TKE and TCR. Keep real values outside tracked files.
OPL_WORKSPACE_DOMAIN=workspace.medopl.cn
OPL_CLOUD_IMAGE=
OPL_K8S_NAMESPACE=opl-cloud
OPL_INGRESS_CLASS=qcloud
OPL_IMAGE_PULL_SECRET_NAME=tcr-pull-secret
OPL_WORKSPACE_STORAGE_CLASS=cbs
TENCENT_DEPLOY_KUBECONFIG_REF=
TENCENT_DEPLOY_CLUSTER_ID=
TENCENT_TCR_REGISTRY=
TENCENT_TCR_NAMESPACE=
TENCENT_TCR_REGION=

# Persistence and OPL final user price catalog.
DATABASE_URL=
OPL_BASIC_COMPUTE_HOURLY_CNY=0.468
OPL_PRO_COMPUTE_HOURLY_CNY=1.38
OPL_STORAGE_GB_MONTH_CNY=0.432

# Package-to-Tencent compute mapping. Set node pool ids when the fixed package
# pools already exist; otherwise the provisioner needs the node-pool creation
# env block.
OPL_BASIC_COMPUTE_INSTANCE_TYPE=
OPL_BASIC_COMPUTE_NODE_POOL_ID=
OPL_PRO_COMPUTE_INSTANCE_TYPE=
OPL_PRO_COMPUTE_NODE_POOL_ID=

# Optional operator-only aggregate endpoint. Leave empty to disable
# GET /api/operator/summary.
OPL_OPERATOR_SUMMARY_TOKEN=

# Commercial auth seed. Prefer OPL_CONSOLE_USERS_JSON from a secret manager.
# Production readiness requires real PI/Admin credentials from secrets.
OPL_CONSOLE_USERS_JSON=
OPL_PI_EMAIL=
OPL_PI_PASSWORD=
OPL_PI_ACCOUNT_ID=
OPL_ADMIN_EMAIL=
OPL_ADMIN_PASSWORD=
OPL_ADMIN_ACCOUNT_ID=
