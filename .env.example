# OPL Cloud runtime provider
OPL_RUNTIME_PROVIDER=local-docker
OPL_PUBLIC_URL=http://127.0.0.1:8787
OPL_WORKSPACE_IMAGE=ghcr.io/gaofeng21cn/one-person-lab-app:latest

# Enable only for local Docker execution.
OPL_LOCAL_DOCKER_EXECUTE=0

# Production uses Tencent TKE and TCR. Keep real values outside tracked files.
OPL_WORKSPACE_DOMAIN=workspace.medopl.cn
OPL_CLOUD_IMAGE=
OPL_K8S_NAMESPACE=opl-cloud
OPL_INGRESS_CLASS=qcloud
OPL_IMAGE_PULL_SECRET_NAME=tcr-pull-secret
OPL_WORKSPACE_STORAGE_CLASS=cbs
TENCENT_DEPLOY_KUBECONFIG_REF=
TENCENT_DEPLOY_CLUSTER_ID=
TENCENT_TCR_REGISTRY=
TENCENT_TCR_NAMESPACE=
TENCENT_TCR_REGION=

# Persistence and internal prepaid billing price catalog.
DATABASE_URL=
OPL_BASIC_COMPUTE_HOURLY_CNY=0.39
OPL_PRO_COMPUTE_HOURLY_CNY=3.09
OPL_STORAGE_GB_MONTH_CNY=0.36
OPL_BILLING_MARKUP=0.2

# Optional operator-only aggregate endpoint. Leave empty to disable
# GET /api/operator/summary.
OPL_OPERATOR_SUMMARY_TOKEN=
