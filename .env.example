# OPL Cloud runtime provider
OPL_RUNTIME_PROVIDER=local-docker
OPL_PUBLIC_URL=http://127.0.0.1:8787
OPL_HARBOR_REGISTRY=
OPL_WORKSPACE_IMAGE=ghcr.io/gaofeng21cn/one-person-lab-webui:latest

# Enable only for local Docker execution.
OPL_LOCAL_DOCKER_EXECUTE=0

# Tencent CVM provider is legacy fallback/debug only. Do not commit real values.
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-guangzhou
OPL_WORKSPACE_DOMAIN=oplcloud.cn
OPL_VPC_ID=
OPL_SUBNET_ID=
OPL_SECURITY_GROUP_ID=
OPL_AVAILABILITY_ZONE=
OPL_IMAGE_ID=
OPL_SSH_KEY_ID=

# Production image should normally come from Harbor.
# Example: harbor.example.com/opl/one-person-lab-webui:latest

# Persistence and internal prepaid billing price catalog.
DATABASE_URL=
OPL_BASIC_COMPUTE_HOURLY_CNY=0.47
OPL_PRO_COMPUTE_HOURLY_CNY=1.65
OPL_STORAGE_GB_MONTH_CNY=0.36
OPL_BILLING_MARKUP=0.2
