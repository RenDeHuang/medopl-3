# OPL Cloud runtime provider
OPL_RUNTIME_PROVIDER=tencent-tke
OPL_PUBLIC_URL=http://127.0.0.1:8787
OPL_WORKSPACE_IMAGE=

# Runtime uses Tencent TKE and TCR. Keep real values outside tracked files.
OPL_WORKSPACE_DOMAIN=workspace.medopl.cn
OPL_CLOUD_IMAGE=
OPL_K8S_NAMESPACE=opl-cloud
OPL_INGRESS_CLASS=qcloud
OPL_IMAGE_PULL_SECRET_NAME=tcr-pull-secret
OPL_WORKSPACE_STORAGE_CLASS=cbs
OPL_TENCENT_ZONE=na-siliconvalley-1
TENCENT_DEPLOY_KUBECONFIG_REF=
TENCENT_DEPLOY_CLUSTER_ID=
TENCENT_TCR_REGISTRY=
TENCENT_TCR_NAMESPACE=
TENCENT_TCR_REGION=

# Persistence. Monthly prices are versioned in the application catalog.
DATABASE_URL=

# Sub2API is the only spendable balance. Keep admin credentials in secrets.
OPL_SUB2API_BASE_URL=https://gflabtoken.cn
OPL_SUB2API_ADMIN_EMAIL=
OPL_SUB2API_ADMIN_PASSWORD=
OPL_SUB2API_REQUEST_TIMEOUT_MS=5000
OPL_MONTHLY_BILLING_WORKER_ENABLED=0
OPL_MONTHLY_BILLING_INTERVAL_MS=3600000

# Package-to-Tencent compute mapping. Monthly preflight discovers exactly one
# existing OPL-labeled node pool for each package and instance type.
OPL_TENCENT_ZONE=
OPL_BASIC_COMPUTE_INSTANCE_TYPE=
OPL_PRO_COMPUTE_INSTANCE_TYPE=

OPL_AIONUI_ADMIN_PASSWORD_SEED=
