{
  "schemaVersion": 1,
  "billingUnit": "hour",
  "markup": 0.2,
  "ledgerEntryTypes": [
    "credit",
    "compute_hold",
    "storage_hold",
    "compute_debit",
    "storage_debit",
    "compute_hold_released",
    "storage_hold_released",
    "compute_auto_stopped",
    "server_billing_stopped",
    "server_destroyed",
    "storage_destroyed",
    "token_reset",
    "token_deleted"
  ],
  "requiredFields": [
    "id",
    "workspaceId",
    "type",
    "amount",
    "currency",
    "sourceEventId",
    "createdAt"
  ],
  "prepaidHoldPolicy": {
    "days": 7,
    "resources": [
      "compute",
      "storage"
    ],
    "chargeOrder": [
      "available_balance",
      "resource_hold"
    ],
    "requiredBefore": [
      "open_workspace",
      "resume_workspace"
    ],
    "unpaidComputeOperationAllowed": false,
    "unpaidStorageOperationAllowed": false
  },
  "tencentBillReconciliation": {
    "command": "npm run reconcile:tencent -- --ledger <ledger.json> --tencent <tencent-bills.json>",
    "markup": 0.2,
    "defaultToleranceCny": 0.01,
    "ledgerUsageTypes": [
      "compute_debit",
      "storage_debit"
    ],
    "legacyLedgerUsageTypes": [
      "server_debit"
    ],
    "tencentBillFields": [
      "workspaceId",
      "resourceType",
      "amount",
      "currency"
    ],
    "rawTencentExport": {
      "supported": true,
      "requiredWorkspaceTag": "workspace_id",
      "cliFlag": "--tencent-format raw"
    },
    "resourceTypes": [
      "server",
      "storage"
    ]
  }
}
