{
  "schemaVersion": 1,
  "product": "OPL Cloud",
  "layers": {
    "gateway": "OPL Gateway",
    "workspace": "OPL Workspace",
    "console": "OPL Console",
    "fabric": "OPL Fabric",
    "ledger": "OPL Ledger"
  },
  "console": "OPL Console",
  "workspace": "OPL Workspace",
  "resourceMapping": {
    "workspace": 1,
    "server": 1,
    "onePersonLabAppDocker": 1,
    "cloudDisk": 1,
    "url": 1
  },
  "access": {
    "urlPattern": "https://workspace.medopl.cn/w/<workspaceId>?token=<share-token>",
    "requiresLogin": false,
    "tokenLifetime": "permanent_until_owner_reset_or_delete"
  },
  "defaultPackages": [
    {
      "id": "basic",
      "name": "Basic Workspace",
      "accelerator": "cpu",
      "cpu": 2,
      "memoryGb": 4,
      "gpu": 0,
      "server": "2c4g",
      "diskGb": 10
    },
    {
      "id": "pro",
      "name": "Pro Workspace",
      "accelerator": "cpu",
      "cpu": 8,
      "memoryGb": 16,
      "gpu": 0,
      "server": "8c16g",
      "diskGb": 100
    },
    {
      "id": "gpu",
      "name": "GPU Workspace",
      "accelerator": "gpu",
      "cpu": 16,
      "memoryGb": 64,
      "gpu": 1,
      "server": "16c64g-1gpu",
      "diskGb": 500
    }
  ],
  "productionHandoff": {
    "manifestExample": "deploy/production-manifest.example.json",
    "validateCommand": "npm run validate:production-manifest -- --manifest <manifest.json>",
    "secretPolicy": "sensitive_values_must_use_secretRef"
  },
  "nonGoals": [
    "member_login_for_shared_urls",
    "automatic_cloud_disk_delete_when_server_stops_or_is_destroyed",
    "kubernetes_default_runtime",
    "external_payment_settlement",
    "live_tencent_price_lookup_before_each_workspace_open"
  ]
}
