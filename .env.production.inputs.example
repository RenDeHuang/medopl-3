# OPL Cloud production operator input template.
#
# Copy this file to .env.production.local and fill real values there.
# .env.production.local is ignored by git through .env.*.

# Images pushed to Tencent TCR.
OPL_CLOUD_IMAGE=
OPL_WORKSPACE_IMAGE=

# Persistence secret. Keep real values out of git.
DATABASE_URL=postgresql://medopl:<password>@10.66.0.21:5432/OPLCloud

# Internal prepaid billing catalog. Values are Tencent cost snapshots before markup.
OPL_BASIC_COMPUTE_HOURLY_CNY=1
OPL_PRO_COMPUTE_HOURLY_CNY=4
OPL_GPU_COMPUTE_HOURLY_CNY=20
OPL_STORAGE_GB_MONTH_CNY=0.2
OPL_BILLING_MARKUP=0.2

# TKE deployment target.
OPL_K8S_NAMESPACE=opl-cloud
OPL_IMAGE_PULL_SECRET_NAME=tcr-pull-secret
OPL_WORKSPACE_STORAGE_CLASS=
TENCENT_DEPLOY_KUBECONFIG_REF=/home/dev/.secrets/medopl/v22/kubeconfig-package-d-deploy
TENCENT_DEPLOY_CLUSTER_ID=
TENCENT_TCR_REGISTRY=
TENCENT_TCR_NAMESPACE=
TENCENT_TCR_REGION=

# Public routing.
OPL_PUBLIC_URL=https://cloud.medopl.cn
OPL_CONSOLE_DOMAIN=cloud.medopl.cn
OPL_WORKSPACE_DOMAIN=workspace.medopl.cn
OPL_INGRESS_CLASS=qcloud
# Tencent TKE qcloud Ingress uses qcloud_cert_id in Opaque Secrets.
# Use OPL_TLS_CERT_ID for one multi-domain/wildcard certificate, or set the two
# per-host certificate ids below for separate single-domain certificates.
OPL_TLS_CERT_ID=
OPL_CONSOLE_TLS_SECRET_NAME=opl-cloud-console-medopl-cn-tls
OPL_CONSOLE_TLS_CERT_ID=
OPL_WORKSPACE_TLS_SECRET_NAME=opl-cloud-workspace-medopl-cn-tls
OPL_WORKSPACE_TLS_CERT_ID=
OPL_INGRESS_CLB_DNS_NAME=
OPL_INGRESS_CLB_IP=

# Workspace runtime defaults.
OPL_WORKSPACE_WEBUI_PORT=3000
OPL_WORKSPACE_DATA_DIR=/data
OPL_WORKSPACE_PROJECTS_DIR=/projects
OPL_WORKSPACE_STORAGE_SIZE_GB=20
OPL_WORKSPACE_NODE_SELECTOR_KEY=medopl.cn/workload
OPL_WORKSPACE_NODE_SELECTOR_VALUE=medopl
